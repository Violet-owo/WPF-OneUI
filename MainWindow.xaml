<Window x:Class="SamsungUi.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SamsungUi.Demo"
        mc:Ignorable="d"
        Title="Samsung One UI Component Gallery" Height="750" Width="1100"
        MinWidth="450" Background="{DynamicResource OneUiBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="SliderStepButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource OneUiTextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-3,0,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="40,50,40,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="One UI per WPF" Foreground="{DynamicResource OneUiTextSecondaryBrush}" FontSize="14" FontWeight="Medium" Margin="0,0,0,4"/>
                <TextBlock Text="Galleria Componenti" Foreground="{DynamicResource OneUiTextPrimaryBrush}" FontSize="36" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Orientation="Horizontal">
                <TextBlock Text="Modalità Notte" Foreground="{DynamicResource OneUiTextSecondaryBrush}" FontSize="14" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <CheckBox Style="{StaticResource ThemeToggleSwitchStyle}" x:Name="ThemeModeToggle" IsChecked="False" Checked="ThemeModeToggle_Checked" Unchecked="ThemeModeToggle_Unchecked"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="MainResponsiveGrid" Margin="28,0,28,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="Col0" Width="1*" />
                    <ColumnDefinition x:Name="Col1" Width="1*" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="LeftPanel" Grid.Column="0" Margin="12,0" HorizontalAlignment="Stretch">
                    <TextBlock Text="Pulsanti e Azioni" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="12,10,12,10"/>

                    <Border Style="{StaticResource OneUiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Controlli di Base" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="I bottoni di One UI hanno angoli fortemente arrotondati (pillola) per mantenere un design fluido e morbido." 
                                       Foreground="{DynamicResource OneUiTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="Annulla" Style="{StaticResource OneUiButtonStyle}" Margin="0,0,12,0"/>
                                <Button Content="Salva impostazioni" Style="{StaticResource OneUiPrimaryButtonStyle}" Margin="0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource OneUiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Collegamenti Rapidi" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,12"/>
                            <Button Content="Connessione Wi-Fi" Style="{StaticResource OneUiButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                            <Button Content="Dispositivi Connessi" Style="{StaticResource OneUiButtonStyle}" HorizontalAlignment="Stretch" Margin="0"/>
                        </StackPanel>
                    </Border>

                    

                    <Border Style="{StaticResource OneUiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Parametrizzazione e Selettori" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,20"/>

                            <StackPanel Margin="0,0,0,20">
                                <Grid Margin="12,0,12,4">
                                    <TextBlock Text="☀️ Luminosità schermo (Continuo)" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding ElementName=BrightnessSlider, Path=Value, StringFormat={}{0:0}%}" 
                                               FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="—" Style="{StaticResource SliderStepButtonStyle}" VerticalAlignment="Center" Margin="4,0"/>
                                    <Slider Grid.Column="1" x:Name="BrightnessSlider" Minimum="0" Maximum="100" Value="65" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="+" Style="{StaticResource SliderStepButtonStyle}" VerticalAlignment="Center" Margin="4,0"/>
                                </Grid>
                            </StackPanel>

                            <Separator/>

                            <StackPanel Margin="0,4,0,20">
                                <Grid Margin="12,0,12,4">
                                    <TextBlock Text="🎵 Volume notifiche (Scatti di 10)" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding ElementName=VolumeSlider, Path=Value, StringFormat={}{0:0}%}" 
                                               FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="—" Style="{StaticResource SliderStepButtonStyle}" VerticalAlignment="Center" Margin="4,0"/>
                                    <Slider Grid.Column="1" x:Name="VolumeSlider" 
                                            Minimum="0" Maximum="100" Value="40" 
                                            TickFrequency="10" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="+" Style="{StaticResource SliderStepButtonStyle}" VerticalAlignment="Center" Margin="4,0"/>
                                </Grid>
                            </StackPanel>

                            <Separator/>

                            <StackPanel Margin="0,4,0,4">
                                <Grid Margin="12,0,12,4">
                                    <TextBlock Text="🔤 Dimensione testo cursore" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding ElementName=TextSizeSlider, Path=Value, StringFormat={}Livello {0:0}}" 
                                               FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="—" Style="{StaticResource SliderStepButtonStyle}" VerticalAlignment="Center" Margin="4,0"/>
                                    <Slider Grid.Column="1" x:Name="TextSizeSlider" 
                                            Minimum="1" Maximum="5" Value="2" 
                                            TickFrequency="1" TickPlacement="BottomRight" IsSnapToTickEnabled="True"
                                            VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="+" Style="{StaticResource SliderStepButtonStyle}" VerticalAlignment="Center" Margin="4,0"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Name="Calendar" Style="{StaticResource OneUiCardStyle}" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding DayNumber}" 
           FontSize="14" 
           FontWeight="Medium"
           HorizontalAlignment="Center" 
           VerticalAlignment="Center"
           Foreground="{DynamicResource OneUiTextPrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <UniformGrid Columns="7" Margin="0,0,0,4">
                                <TextBlock Text="L" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="M" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="M" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="G" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="V" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="S" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="D" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                            </UniformGrid>

                            <ListBox ItemsSource="{Binding CalendarDays}" 
                 Style="{StaticResource OneUiCalendarStyle}"
                 SelectionMode="Single"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel x:Name="RightPanel" Grid.Column="1" Margin="12,0" HorizontalAlignment="Stretch">
                    <TextBlock Text="Indicatori di Stato" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="12,10,12,10"/>

                    <Border Style="{StaticResource OneUiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Assistenza Dispositivo" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="🔋 Batteria" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                    <TextBlock Text="10 h 23 m rimasti" FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </Grid>
                                <TextBlock Text="98%" FontSize="20" FontWeight="Bold" Margin="0,4,0,8" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                <ProgressBar Value="98" Maximum="100"/>
                            </StackPanel>
                            <Separator/>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="💾 Spazio di archiviazione" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                    <TextBlock Text="225,9 GB / 256 GB" FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </Grid>
                                <TextBlock Text="88% utilizzato" FontSize="20" FontWeight="Bold" Margin="0,4,0,8" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                <ProgressBar Value="88" Maximum="100"/>
                            </StackPanel>
                            <Separator/>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="⚡ Memoria" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                    <TextBlock Text="8,2 GB / 12 GB" FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </Grid>
                                <TextBlock Text="67% utilizzato" FontSize="20" FontWeight="Bold" Margin="0,4,0,8" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                <ProgressBar Value="67" Maximum="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource OneUiCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Impostazioni Funzioni" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                            <Grid>
                                <StackPanel Margin="0,0,50,0">
                                    <TextBlock Text="Risparmio energetico" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                    <TextBlock Text="Riduci l'uso dei dati in background e le prestazioni visive." FontSize="13" Foreground="{DynamicResource OneUiTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Style="{StaticResource OneUiToggleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="False"/>
                            </Grid>
                            <Separator/>
                            <Grid>
                                <StackPanel Margin="0,0,50,0">
                                    <TextBlock Text="Barra di navigazione trasparente" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                    <TextBlock Text="Rendi trasparente lo sfondo dei controlli di navigazione inferiori." FontSize="13" Foreground="{DynamicResource OneUiTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                                <CheckBox Style="{StaticResource OneUiToggleSwitchStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" IsChecked="True"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource OneUiCardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="Utilizzo schermo" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                    <TextBlock Text="Media giornaliera: 2 h 41 min" FontSize="13" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Text="Dettagli" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiSliderActiveBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                            </Grid>

                            <Grid Height="180" VerticalAlignment="Bottom" Margin="0,10,0,0">
                                <ItemsControl ItemsSource="{Binding WeeklyUsageData}" Style="{StaticResource OneUiBarChartStyle}" AlternationCount="2"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>