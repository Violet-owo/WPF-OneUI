<Window x:Class="SamsungUi.Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SamsungUi.Demo"
        xmlns:sui="clr-namespace:SamsungUi.Controls;assembly=SamsungUi"
        mc:Ignorable="d"
        Title="Samsung One UI WPF Component Gallery" Height="750" Width="1100"
        MinWidth="450" Background="{DynamicResource OneUiBackgroundBrush}" FontFamily="Roboto, Segoe UI">

    <AdornerDecorator>
        <Grid>
            <!-- Title Bar -->
            <TextBlock Text="Component Gallery" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="24,24,24,16" VerticalAlignment="Top"/>

            <!-- Main Content Area (Pages) -->
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="0,70,0,100" />

            <!-- Navigation Bar at the bottom -->
            <sui:SamsungNavigationBar x:Name="NavBar" VerticalAlignment="Bottom" Margin="0,0,0,24" SelectionChanged="NavBar_SelectionChanged">
                <!-- Icons using Segoe Fluent Icons: E771=List/Controls, E787=Calendar/Modules, E713=Settings -->
                <sui:SamsungNavigationBarItem Icon="&#xE771;" Text="Controls" IsSelected="True"/>
                <sui:SamsungNavigationBarItem Icon="&#xE787;" Text="Modules"/>
                <sui:SamsungNavigationBarItem Icon="&#xE8B9;" Text="Gallery"/>
                <sui:SamsungNavigationBarItem Icon="&#xE916;" Text="Stopwatch"/>
                <sui:SamsungNavigationBarItem Icon="&#xE713;" Text="Settings"/>
            </sui:SamsungNavigationBar>
        </Grid>
    </AdornerDecorator>
</Window>