<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sui="clr-namespace:SamsungUi.Controls">

    <Style x:Key="ThemeToggleSwitchStyle" TargetType="{x:Type sui:SamsungToggleSwitch}">
        <Setter Property="Background" Value="{DynamicResource OneUiCardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungToggleSwitch}">
                    <StackPanel Orientation="Horizontal">
                        <Grid x:Name="SwitchContainer" Width="54" Height="30">
                            <Border x:Name="Track" Background="#EAE2F0" CornerRadius="15" SnapsToDevicePixels="True"/>

                            <Border x:Name="Thumb" Background="#FFFFFF" Width="24" Height="24" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0" SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.15" Color="#000000"/>
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                        <RotateTransform x:Name="ThumbRotate" Angle="0" CenterX="12" CenterY="12"/>
                                    </TransformGroup>
                                </Border.RenderTransform>

                                <Grid>
                                    <Viewbox x:Name="SunIcon" Width="14" Height="14" Opacity="1">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="#FFB300" Data="M12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7M12,2A1,1 0 0,1 13,3V5A1,1 0 0,1 12,6A1,1 0 0,1 11,5V3A1,1 0 0,1 12,2M12,18A1,1 0 0,1 13,19V21A1,1 0 0,1 12,22A1,1 0 0,1 11,21V19A1,1 0 0,1 12,18M22,12A1,1 0 0,1 21,13H19A1,1 0 0,1 18,12A1,1 0 0,1 19,11H21A1,1 0 0,1 22,12M6,12A1,1 0 0,1 5,13H3A1,1 0 0,1 2,12A1,1 0 0,1 3,11H5A1,1 0 0,1 6,12M19.07,4.93A1,1 0 0,1 19.07,6.34L17.66,7.76A1,1 0 0,1 16.24,7.76A1,1 0 0,1 16.24,6.34L17.66,4.93A1,1 0 0,1 19.07,4.93M7.76,16.24A1,1 0 0,1 7.76,17.66L6.34,19.07A1,1 0 0,1 4.93,19.07A1,1 0 0,1 4.93,17.66L6.34,16.24A1,1 0 0,1 7.76,16.24M19.07,19.07A1,1 0 0,1 17.66,19.07L16.24,17.66A1,1 0 0,1 16.24,16.24A1,1 0 0,1 17.66,16.24L19.07,17.66A1,1 0 0,1 19.07,19.07M7.76,7.76A1,1 0 0,1 6.34,7.76L4.93,6.34A1,1 0 0,1 4.93,4.93A1,1 0 0,1 6.34,4.93L7.76,6.34A1,1 0 0,1 7.76,7.76Z"/>
                                        </Canvas>
                                    </Viewbox>

                                    <Viewbox x:Name="MoonIcon" Width="13" Height="13" Opacity="0">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="#765091" Data="M12.3,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 21.75,9.75C20.91,10.54 19.78,11 18.5,11A5.5,5.5 0 0,1 13,5.5C13,4.22 13.46,3.09 14.25,2.25C13.62,2.09 12.97,2 12.3,2Z"/>
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Border>
                        </Grid>
                        <ContentPresenter x:Name="ContentArea" Content="{TemplateBinding Content}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="24" Duration="0:0:0.5" DecelerationRatio="0.8"/>
                                        <DoubleAnimation Storyboard.TargetName="ThumbRotate" Storyboard.TargetProperty="Angle" To="360" Duration="0:0:0.55"/>
                                        <ColorAnimation Storyboard.TargetName="Track" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#2D2D30" Duration="0:0:0.4"/>
                                        <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.35"/>
                                        <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.35"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.5" DecelerationRatio="0.8"/>
                                        <DoubleAnimation Storyboard.TargetName="ThumbRotate" Storyboard.TargetProperty="Angle" To="0" Duration="0:0:0.55"/>
                                        <ColorAnimation Storyboard.TargetName="Track" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#EAE2F0" Duration="0:0:0.4"/>
                                        <DoubleAnimation Storyboard.TargetName="SunIcon" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.35"/>
                                        <DoubleAnimation Storyboard.TargetName="MoonIcon" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.35"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OneUiSliderThumbStyle" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="true"/>
        <Setter Property="OverridesDefaultStyle" Value="true"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Container" 
                            Background="{DynamicResource OneUiSliderActiveBrush}" 
                            Width="22" 
                            Height="22" 
                            CornerRadius="11" 
                            VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.15" Color="#000000"/>
                        </Border.Effect>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sui:SamsungSlider}">
        <Setter Property="Background" Value="{DynamicResource OneUiSliderTrackBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiSliderActiveBrush}"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungSlider}">
                    <Grid x:Name="CustomSliderLayout" VerticalAlignment="Center" Background="Transparent">

                        <Border x:Name="TrackBackground" 
                                Background="{TemplateBinding Background}" 
                                Height="6" 
                                CornerRadius="3" 
                                VerticalAlignment="Center" 
                                Margin="11,0"/>

                        <TickBar x:Name="TopTick" 
                                 Visibility="Collapsed" 
                                 Placement="Bottom" 
                                 Height="4" 
                                 Fill="{DynamicResource OneUiSliderTickBrush}" 
                                 VerticalAlignment="Center" 
                                 Margin="11,0"/>

                        <Track x:Name="PART_Track" Margin="11,0">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="{TemplateBinding Foreground}" Height="6" CornerRadius="3"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>

                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Background="Transparent" Height="6"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>

                            <Track.Thumb>
                                <Thumb Style="{StaticResource OneUiSliderThumbStyle}" VerticalAlignment="Center"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="TickPlacement" Value="TopLeft">
                            <Setter TargetName="TopTick" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="TickPlacement" Value="BottomRight">
                            <Setter TargetName="TopTick" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="TickPlacement" Value="Both">
                            <Setter TargetName="TopTick" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sui:SamsungToggleSwitch}">
        <Setter Property="Background" Value="#D1D1D6"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungToggleSwitch}">
                    <StackPanel Orientation="Horizontal">
                        <Grid x:Name="SwitchContainer" Width="44" Height="24">
                            <Border x:Name="Track" Background="{TemplateBinding Background}" CornerRadius="12" BorderThickness="0" SnapsToDevicePixels="True"/>
                            <Border x:Name="Thumb" Background="#FFFFFF" Width="18" Height="18" CornerRadius="9" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0" SnapsToDevicePixels="True">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ContentPresenter x:Name="ContentArea" Content="{TemplateBinding Content}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.15" DecelerationRatio="0.8"/>
                                        <ColorAnimation Storyboard.TargetName="Track" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#765091" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.15" DecelerationRatio="0.8"/>
                                        <ColorAnimation Storyboard.TargetName="Track" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#D1D1D6" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>