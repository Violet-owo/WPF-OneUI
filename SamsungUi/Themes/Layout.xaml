<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sui="clr-namespace:SamsungUi.Controls"
                    xmlns:localControls="clr-namespace:SamsungUi.Controls">

    <!-- ========================================== -->
    <!-- EXPANDABLE PAGE (SCROLLING BEHAVIOR)       -->
    <!-- ========================================== -->
    
    <Style TargetType="{x:Type localControls:SamsungExpandablePage}">
        <Setter Property="Background" Value="{DynamicResource OneUiBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="50"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:SamsungExpandablePage}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Small Header -->
                            <RowDefinition Height="*"/>    <!-- ScrollViewer -->
                        </Grid.RowDefinitions>
                        
                        <!-- Main Content Scroll -->
                        <ScrollViewer x:Name="PART_ScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Panel.ZIndex="1">
                            <StackPanel>
                                <!-- Big Header (Viewing Area) -->
                                <Grid x:Name="PART_BigHeader" Height="160">
                                    <TextBlock x:Name="PART_BigHeaderTitle" 
                                               Text="{TemplateBinding PageTitle}" 
                                               FontSize="34" FontWeight="Bold" 
                                               Foreground="{DynamicResource OneUiTextPrimaryBrush}" 
                                               Margin="24,0,24,24" 
                                               VerticalAlignment="Bottom"/>
                                </Grid>
                                
                                <!-- Content Area -->
                                <ContentPresenter Margin="0"/>
                                
                                <!-- Bottom padding for navbar -->
                                <Grid Height="100"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Small Header (Sticky top) -->
                        <Border x:Name="PART_SmallHeader" Grid.Row="0" Height="60" Opacity="0" Background="{DynamicResource OneUiBackgroundBrush}" Panel.ZIndex="10">
                            <TextBlock Text="{TemplateBinding PageTitle}" 
                                       FontSize="18" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource OneUiTextPrimaryBrush}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35" DecelerationRatio="0.8"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="50" To="0" Duration="0:0:0.4" DecelerationRatio="0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- TAB CONTROL & TAB ITEM (TOP TABS)          -->
    <!-- ========================================== -->
    <Style TargetType="{x:Type sui:SamsungTabControl}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0,16,0,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungTabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Tab Headers -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Orientation="Horizontal" x:Name="HeaderPanel" 
                                      Grid.Row="0" 
                                      Panel.ZIndex="1" 
                                      Margin="24,0,24,0" 
                                      IsItemsHost="True" 
                                      KeyboardNavigation.TabIndex="1" 
                                      Background="Transparent"/>
                        </ScrollViewer>
                        <ContentPresenter x:Name="PART_SelectedContentHost" 
                                          Grid.Row="1" 
                                          Margin="{TemplateBinding Padding}" 
                                          ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sui:SamsungTabItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,24,0"/>
        <Setter Property="Padding" Value="0,12,0,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungTabItem}">
                    <Grid Background="{TemplateBinding Background}">
                        <ContentPresenter x:Name="ContentSite"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"/>
                        
                        <!-- Indicator (Pill) -->
                        <Border x:Name="Indicator" 
                                Height="3" 
                                CornerRadius="1.5" 
                                Background="{DynamicResource OneUiPrimaryBrush}" 
                                VerticalAlignment="Bottom" 
                                Opacity="0"
                                Margin="0,0,0,-2"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
                            <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- MODAL & OVERLAY (DIALOGS)                  -->
    <!-- ========================================== -->
    <Style TargetType="{x:Type localControls:SamsungModal}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:SamsungModal}">
                    <!-- Renders nothing in place. Content is moved to the Adorner layer. -->
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SamsungModalOverlayStyle" TargetType="{x:Type ContentControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Grid x:Name="RootGrid" Background="Transparent">
                        <Border Background="#66000000" x:Name="Overlay" Opacity="0"/>
                        <Border x:Name="DialogContainer" 
                                Background="{DynamicResource OneUiControlBackgroundBrush}" 
                                CornerRadius="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center" 
                                Padding="24" 
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True"
                                Opacity="0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.1" Direction="270"/>
                            </Border.Effect>
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                            </Border.RenderTransform>
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SamsungFullscreenModalOverlayStyle" TargetType="{x:Type ContentControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Grid x:Name="RootGrid" Background="Transparent">
                        <!-- Immersive dark background -->
                        <Border Background="#E6000000" x:Name="Overlay" Opacity="0"/>
                        <!-- Fullscreen container without borders, shadows or padding -->
                        <Border x:Name="DialogContainer" 
                                Background="Transparent" 
                                HorizontalAlignment="Stretch" 
                                VerticalAlignment="Stretch" 
                                Padding="0" 
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True"
                                Opacity="0">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                            </Border.RenderTransform>
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.2" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.2" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- GALLERY CONTROLS                           -->
    <!-- ========================================== -->

    <!-- SamsungGridViewBig: rendering done via OnRender in C# -->
    <Style TargetType="{x:Type localControls:SamsungGridViewBig}">
        <Setter Property="Margin" Value="2"/>
    </Style>

    <!-- SamsungGridViewMedium: rendering done via OnRender in C# -->
    <Style TargetType="{x:Type localControls:SamsungGridViewMedium}">
        <Setter Property="Margin" Value="2"/>
    </Style>

    <!-- SamsungGridViewSmall: rendering done via OnRender in C# -->
    <Style TargetType="{x:Type localControls:SamsungGridViewSmall}">
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style TargetType="{x:Type localControls:SamsungListViewImageText}">
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:SamsungListViewImageText}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" RadiusX="12" RadiusY="12" Width="56" Height="56" Margin="0,0,16,0">
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ImageSource}" Stretch="UniformToFill"/>
                            </Rectangle.Fill>
                        </Rectangle>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding MainText}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="{TemplateBinding SubText}" FontSize="14" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
