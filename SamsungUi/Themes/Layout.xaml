<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sui="clr-namespace:SamsungUi.Controls"
                    xmlns:localControls="clr-namespace:SamsungUi.Controls">

    <!-- ========================================== -->
    <!-- EXPANDABLE PAGE (SCROLLING BEHAVIOR)       -->
    <!-- ========================================== -->
    
    <Style TargetType="{x:Type localControls:SamsungExpandablePage}">
        <Setter Property="Background" Value="{DynamicResource OneUiBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="50"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:SamsungExpandablePage}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Small Header -->
                            <RowDefinition Height="*"/>    <!-- ScrollViewer -->
                        </Grid.RowDefinitions>
                        
                        <!-- Main Content Scroll -->
                        <ScrollViewer x:Name="PART_ScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Panel.ZIndex="1">
                            <StackPanel>
                                <!-- Big Header (Viewing Area) -->
                                <Grid x:Name="PART_BigHeader" Height="160">
                                    <TextBlock x:Name="PART_BigHeaderTitle" 
                                               Text="{TemplateBinding PageTitle}" 
                                               FontSize="{DynamicResource OneUiPageTitleFontSize}" FontWeight="Bold" 
                                               Foreground="{DynamicResource OneUiTextPrimaryBrush}" 
                                               Margin="24,0,24,24" 
                                               VerticalAlignment="Bottom"/>
                                </Grid>
                                
                                <!-- Content Area -->
                                <ContentPresenter Margin="0"/>
                                
                                <!-- Bottom padding for navbar -->
                                <Grid Height="100"/>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Small Header (Sticky top) -->
                        <Border x:Name="PART_SmallHeader" Grid.Row="0" Height="60" Opacity="0" Background="{DynamicResource OneUiBackgroundBrush}" Panel.ZIndex="10">
                            <TextBlock Text="{TemplateBinding PageTitle}" 
                                       FontSize="{DynamicResource OneUiSubtitleFontSize}" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource OneUiTextPrimaryBrush}" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35" DecelerationRatio="0.8"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="50" To="0" Duration="0:0:0.4" DecelerationRatio="0.8"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- TAB CONTROL & TAB ITEM (TOP TABS)          -->
    <!-- ========================================== -->
    <Style TargetType="{x:Type sui:SamsungTabControl}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0,16,0,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungTabControl}">
                    <Grid KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <!-- Tab Headers -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Orientation="Horizontal" x:Name="HeaderPanel" 
                                      Grid.Row="0" 
                                      Panel.ZIndex="1" 
                                      Margin="24,0,24,0" 
                                      IsItemsHost="True" 
                                      KeyboardNavigation.TabIndex="1" 
                                      Background="Transparent"/>
                        </ScrollViewer>
                        <ContentPresenter x:Name="PART_SelectedContentHost" 
                                          Grid.Row="1" 
                                          Margin="{TemplateBinding Padding}" 
                                          ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type sui:SamsungTabItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{DynamicResource OneUiSubtitleFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,24,0"/>
        <Setter Property="Padding" Value="0,12,0,12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungTabItem}">
                    <Grid Background="{TemplateBinding Background}">
                        <ContentPresenter x:Name="ContentSite"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          ContentSource="Header"
                                          Margin="{TemplateBinding Padding}"/>
                        
                        <!-- Indicator (Pill) -->
                        <Border x:Name="Indicator" 
                                Height="3" 
                                CornerRadius="1.5" 
                                Background="{DynamicResource OneUiPrimaryBrush}" 
                                VerticalAlignment="Bottom" 
                                Opacity="0"
                                Margin="0,0,0,-2"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
                            <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- MODAL & OVERLAY (DIALOGS)                  -->
    <!-- ========================================== -->
    <Style TargetType="{x:Type localControls:SamsungModal}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:SamsungModal}">
                    <!-- Renders nothing in place. Content is moved to the Adorner layer. -->
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SamsungModalOverlayStyle" TargetType="{x:Type ContentControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Grid x:Name="RootGrid" Background="Transparent">
                        <Border Background="#66000000" x:Name="Overlay" Opacity="0"/>
                        <Border x:Name="DialogContainer" 
                                Background="{DynamicResource OneUiControlBackgroundBrush}" 
                                CornerRadius="24" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center" 
                                Padding="24" 
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True"
                                Opacity="0"
                                Effect="{DynamicResource OneUiModalShadow}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                            </Border.RenderTransform>
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SamsungFullscreenModalOverlayStyle" TargetType="{x:Type ContentControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Grid x:Name="RootGrid" Background="Transparent">
                        <!-- Immersive dark background -->
                        <Border Background="#E6000000" x:Name="Overlay" Opacity="0"/>
                        <!-- Fullscreen container without borders, shadows or padding -->
                        <Border x:Name="DialogContainer" 
                                Background="Transparent" 
                                HorizontalAlignment="Stretch" 
                                VerticalAlignment="Stretch" 
                                Padding="0" 
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True"
                                Opacity="0">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                            </Border.RenderTransform>
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Overlay" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.2" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="DialogContainer" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.2" To="1" Duration="0:0:0.25">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- GALLERY CONTROLS                           -->
    <!-- ========================================== -->

    <!-- SamsungGridViewBig: rendering done via OnRender in C# -->
    <Style TargetType="{x:Type localControls:SamsungGridViewBig}">
        <Setter Property="Margin" Value="2"/>
    </Style>

    <!-- SamsungGridViewMedium: rendering done via OnRender in C# -->
    <Style TargetType="{x:Type localControls:SamsungGridViewMedium}">
        <Setter Property="Margin" Value="2"/>
    </Style>

    <!-- SamsungGridViewSmall: rendering done via OnRender in C# -->
    <Style TargetType="{x:Type localControls:SamsungGridViewSmall}">
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style TargetType="{x:Type localControls:SamsungListViewImageText}">
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type localControls:SamsungListViewImageText}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" RadiusX="12" RadiusY="12" Width="56" Height="56" Margin="0,0,16,0">
                            <Rectangle.Fill>
                                <ImageBrush ImageSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ImageSource}" Stretch="UniformToFill"/>
                            </Rectangle.Fill>
                        </Rectangle>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{TemplateBinding MainText}" FontSize="{DynamicResource OneUiSubtitleFontSize}" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,2"/>
                            <TextBlock Text="{TemplateBinding SubText}" FontSize="{DynamicResource OneUiNormalFontSize}" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- SAMSUNG GROUPBOX                           -->
    <!-- ========================================== -->
    <Style TargetType="{x:Type sui:SamsungGroupBox}">
        <Setter Property="Background" Value="{DynamicResource OneUiSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource OneUiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungGroupBox}">
                    <Border Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            CornerRadius="26"
                            Padding="{TemplateBinding Padding}"
                            Effect="{DynamicResource OneUiCardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Header with Icon and Text -->
                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" 
                                                  Content="{TemplateBinding IconContent}" 
                                                  Margin="0,0,12,0"
                                                  VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" 
                                                  ContentSource="Header" RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"
                                                  TextBlock.FontWeight="SemiBold"
                                                  TextBlock.FontSize="{DynamicResource OneUiSubtitleFontSize}"
                                                  TextBlock.Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                            </Grid>
                            
                            <!-- Content -->
                            <ContentPresenter Grid.Row="1" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- SAMSUNG EXPANDER (Overlay Style)           -->
    <!-- ========================================== -->
    <Style TargetType="{x:Type sui:SamsungExpander}">
        <Setter Property="Background" Value="{DynamicResource OneUiSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource OneUiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
        <Setter Property="Padding" Value="24,16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungExpander}">
                    <Grid>
                        <ToggleButton x:Name="HeaderButton"
                                      IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Background="{TemplateBinding Background}" 
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Foreground="{TemplateBinding Foreground}"
                                      Padding="{TemplateBinding Padding}" 
                                      HorizontalContentAlignment="Stretch"
                                      Cursor="Hand"
                                      FocusVisualStyle="{x:Null}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="26"
                                            Padding="{TemplateBinding Padding}"
                                            x:Name="BgBorder"
                                            Effect="{DynamicResource OneUiCardShadow}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <ContentPresenter Grid.Column="0" 
                                                              Content="{Binding IconContent, RelativeSource={RelativeSource AncestorType=sui:SamsungExpander}}" 
                                                              Margin="0,0,12,0"
                                                              VerticalAlignment="Center"/>
                                            
                                            <ContentPresenter Grid.Column="1" 
                                                              Content="{Binding Header, RelativeSource={RelativeSource AncestorType=sui:SamsungExpander}}" 
                                                              VerticalAlignment="Center"
                                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                                              TextBlock.FontWeight="SemiBold" TextBlock.FontSize="{DynamicResource OneUiSubtitleFontSize}"/>
                                            
                                            <Path x:Name="Arrow" Grid.Column="2" 
                                                  Data="M 0 0 L 6 6 L 12 0" 
                                                  Stroke="{DynamicResource OneUiTextPrimaryBrush}" StrokeThickness="2" 
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="0"/>
                                                </Path.RenderTransform>
                                            </Path>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="180" Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="Arrow" Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" To="0" Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource OneUiControlBackgroundHoverBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        
                        <!-- Expanded Content in Popup (Overlay) -->
                        <Popup IsOpen="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                               PlacementTarget="{Binding ElementName=HeaderButton}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               StaysOpen="False">
                            <Border x:Name="ContentBorder" 
                                    Background="{DynamicResource OneUiSurfaceBrush}" 
                                    CornerRadius="26"
                                    Margin="8,4,8,16" 
                                    Width="{Binding ActualWidth, ElementName=HeaderButton}"
                                    Effect="{DynamicResource OneUiCardShadow}">
                                <ContentPresenter x:Name="ExpandSite" Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================================== -->
    <!-- SAMSUNG LIST VIEW & ITEMS                  -->
    <!-- ========================================== -->

    <!-- SamsungListViewItem -->
    <Style TargetType="{x:Type sui:SamsungListViewItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource OneUiBorderBrush}"/>
        <Setter Property="Padding" Value="0,16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungListViewItem}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Icon Content -->
                            <ContentPresenter Grid.Column="0" 
                                              Content="{TemplateBinding IconContent}"
                                              Margin="16,0,16,0"
                                              VerticalAlignment="Center"/>
                            
                            <!-- Main Content & Separator -->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <ContentPresenter Grid.Row="0"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                
                                <!-- Separator -->
                                <Border x:Name="Separator" 
                                        Grid.Row="1" 
                                        Height="1" 
                                        Background="{TemplateBinding BorderBrush}" 
                                        Opacity="1.0"
                                        Margin="0,0,16,0"
                                        Visibility="Visible"/>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource OneUiControlBackgroundHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource OneUiControlBackgroundPressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SamsungListView -->
    <Style TargetType="{x:Type sui:SamsungListView}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungListView}">
                    <Border BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            Background="{TemplateBinding Background}" 
                            SnapsToDevicePixels="True">
                        <sui:SamsungScrollViewer Focusable="False" 
                                                 Padding="{TemplateBinding Padding}">
                            <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </sui:SamsungScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
