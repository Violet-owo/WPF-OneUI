<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sui="clr-namespace:SamsungUi.Controls">

    <Style x:Key="OneUiCalendarHeaderStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{DynamicResource OneUiSmallFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>

    <Style x:Key="OneUiCalendarDayStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid Background="Transparent" SnapsToDevicePixels="true">
                        <Border x:Name="SelectionHighlight"
                                Width="36"
                                Height="36"
                                CornerRadius="18"
                                Background="{DynamicResource OneUiCalendarSelectedBrush}"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center" 
                                          Margin="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="true">
                            <Setter TargetName="SelectionHighlight" Property="Visibility" Value="Visible"/>
                            <Setter Property="Foreground" Value="{DynamicResource OneUiCalendarSelectedTextBrush}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="true"/>
                                <Condition Property="IsSelected" Value="false"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SelectionHighlight" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="SelectionHighlight" Property="Background" Value="{DynamicResource OneUiCalendarHoverBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OneUiCalendarStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource OneUiCalendarDayStyle}"/>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid Width="36" Height="36">
                        <TextBlock Text="{Binding DayNumber}" 
                                   FontSize="{DynamicResource OneUiNormalFontSize}" 
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                            <Setter Property="Opacity" Value="0.3"/>
                                        </DataTrigger>

                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsToday}" Value="True"/>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Foreground" Value="{DynamicResource OneUiCalendarTodayTextBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </MultiDataTrigger>

                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource OneUiCalendarSelectedTextBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Event dot -->
                        <Ellipse Width="4" Height="4" Margin="0,0,0,4"
                                 Fill="{Binding FirstEvent.DotColor}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Bottom">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasEvents}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <!-- Hide the dot if the day is not in the current month -->
                                        <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Event Detail Popup -->
                        <Popup AllowsTransparency="True" StaysOpen="False" Placement="Bottom" VerticalOffset="4">
                            <Popup.Style>
                                <Style TargetType="Popup">
                                    <Setter Property="IsOpen" Value="False"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasEvents}" Value="True"/>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"/>
                                                <!-- Show popup only for the current month -->
                                                <Condition Binding="{Binding IsCurrentMonth}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="IsOpen" Value="True"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Popup.Style>
                            
                            <Border Background="{DynamicResource OneUiSurfaceBrush}" 
                                    CornerRadius="12" Padding="16" Margin="12" MaxWidth="250"
                                    BorderBrush="{DynamicResource OneUiControlBackgroundBrush}" BorderThickness="1"
                                    Effect="{DynamicResource OneUiPopupShadow}">
                                <!-- Entry Animation -->
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.9" To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.9" To="1" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <Border.RenderTransform>
                                    <ScaleTransform CenterX="0" CenterY="0"/>
                                </Border.RenderTransform>
                                
                                <StackPanel>
                                    <TextBlock Text="{Binding FirstEvent.Title}" FontWeight="Bold" FontSize="{DynamicResource OneUiNormalFontSize}" Foreground="{DynamicResource OneUiTextPrimaryBrush}" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding FirstEvent.Description}" FontSize="{DynamicResource OneUiSmallFontSize}" Foreground="{DynamicResource OneUiTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SamsungCalendar Default Style -->
    <Style TargetType="{x:Type sui:SamsungCalendar}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungCalendar}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <StackPanel>
                            <!-- Header (Month/Year and Navigation) -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Prev Button -->
                                <Button x:Name="PART_PrevMonthButton" Grid.Column="0" Width="40" Height="40" Cursor="Hand" Background="Transparent" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="20">
                                                <TextBlock Text="&lt;" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource OneUiTextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource OneUiBorderBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Header Text -->
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding HeaderText, RelativeSource={RelativeSource AncestorType=sui:SamsungCalendar}}" 
                                           FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                           Foreground="{DynamicResource OneUiTextPrimaryBrush}" />

                                <!-- Next Button -->
                                <Button x:Name="PART_NextMonthButton" Grid.Column="2" Width="40" Height="40" Cursor="Hand" Background="Transparent" BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="20">
                                                <TextBlock Text="&gt;" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource OneUiTextSecondaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource OneUiBorderBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Week Days -->
                            <ItemsControl ItemsSource="{Binding WeekDays, RelativeSource={RelativeSource AncestorType=sui:SamsungCalendar}}" Margin="0,0,0,8">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Calendar Days -->
                            <ListBox ItemsSource="{Binding CalendarDays, RelativeSource={RelativeSource AncestorType=sui:SamsungCalendar}}"
                                     Style="{StaticResource OneUiCalendarStyle}"
                                     SelectionMode="Single"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>