<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sui="clr-namespace:SamsungUi.Controls">

    <!-- Stile per la Card Contenitore in stile Samsung One UI -->
    <Style TargetType="{x:Type sui:SamsungCard}">
        <Setter Property="Background" Value="{DynamicResource OneUiSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungCard}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="26"
                            Padding="{TemplateBinding Padding}">
                        <!-- Effetto ombra leggerissimo e morbido tipico di One UI -->
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" 
                                              ShadowDepth="2" 
                                              Opacity="0.04" 
                                              Color="Black"/>
                        </Border.Effect>
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>