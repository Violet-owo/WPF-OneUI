<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sui="clr-namespace:SamsungUi.Controls">

    <Style TargetType="{x:Type sui:SamsungFileDropZone}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource OneUiBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{DynamicResource OneUiNormalFontSize}"/>
        <Setter Property="MinHeight" Value="120"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungFileDropZone}">
                    <Grid>
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                        </Border>
                        <Rectangle x:Name="DashedRect" RadiusX="14" RadiusY="14" Stroke="{TemplateBinding BorderBrush}" StrokeThickness="{TemplateBinding BorderThickness}" StrokeDashArray="4 4" Fill="Transparent"/>
                        
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Icon}" 
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" 
                                       FontSize="32" 
                                       HorizontalAlignment="Center" 
                                       Foreground="{DynamicResource OneUiPrimaryBrush}" 
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{TemplateBinding Text}" 
                                       FontSize="{TemplateBinding FontSize}" 
                                       Foreground="{TemplateBinding Foreground}" 
                                       HorizontalAlignment="Center" 
                                       TextWrapping="Wrap" 
                                       TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDragOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource OneUiControlBackgroundBrush}"/>
                            <Setter TargetName="DashedRect" Property="Stroke" Value="{DynamicResource OneUiPrimaryBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource OneUiPrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
