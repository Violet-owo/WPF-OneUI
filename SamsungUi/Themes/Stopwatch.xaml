<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sui="clr-namespace:SamsungUi.Controls">

    <!-- ============================================== -->
    <!-- SAMSUNG MINI STOPWATCH (PiP)                  -->
    <!-- ============================================== -->
    <Style TargetType="{x:Type sui:SamsungMiniStopwatch}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungMiniStopwatch}">
                    <Border x:Name="MiniBorder" Background="{DynamicResource OneUiSurfaceBrush}" CornerRadius="26" Padding="6,6,6,6" Margin="16"
                            BorderThickness="0"
                            Effect="{DynamicResource OneUiPopupShadow}">
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Drag handle/Time -->
                                <ColumnDefinition Width="Auto"/> <!-- Lap Button -->
                                <ColumnDefinition Width="Auto"/> <!-- Start Button -->
                                <ColumnDefinition Width="Auto"/> <!-- Close Button -->
                            </Grid.ColumnDefinitions>

                            <!-- Thumb for Dragging (also holds the Time text) -->
                            <Thumb x:Name="PART_MiniThumb" Grid.Column="0" Background="Transparent" Cursor="SizeAll" MinWidth="100" Margin="10,0,10,0">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Fill="#0381FE" Margin="0,0,8,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunning, RelativeSource={RelativeSource AncestorType=sui:SamsungMiniStopwatch}}" Value="True">
                                                                    <Setter Property="Fill" Value="#E3A8B1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding ElapsedTimeText, RelativeSource={RelativeSource AncestorType=sui:SamsungMiniStopwatch}}" 
                                                           Foreground="{DynamicResource OneUiTextPrimaryBrush}" FontSize="20" FontWeight="Bold" FontFamily="Consolas, Courier New"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>

                            <!-- Mini Lap Button -->
                            <Button x:Name="PART_MiniLapButton" Grid.Column="1" Width="40" Height="40" Margin="4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="20" Background="{DynamicResource OneUiControlBackgroundBrush}">
                                            <TextBlock Text="{Binding LapButtonText, RelativeSource={RelativeSource AncestorType=sui:SamsungMiniStopwatch}}"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource OneUiControlBackgroundHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Mini Start/Stop Button -->
                            <Button x:Name="PART_MiniStartButton" Grid.Column="2" Width="40" Height="40" Margin="4,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="MiniBg" CornerRadius="20" Background="#D1BCE3">
                                            <TextBlock Text="{Binding StartButtonText, RelativeSource={RelativeSource AncestorType=sui:SamsungMiniStopwatch}}"
                                                       FontSize="12" FontWeight="SemiBold" Foreground="#111111" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning, RelativeSource={RelativeSource AncestorType=sui:SamsungMiniStopwatch}}" Value="True">
                                                <Setter TargetName="MiniBg" Property="Background" Value="#E3A8B1"/>
                                            </DataTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="MiniBg" Property="Opacity" Value="0.8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <!-- Mini Close Button -->
                            <Button x:Name="PART_MiniCloseButton" Grid.Column="3" Width="36" Height="36" Margin="8,0,0,0" ToolTip="Close PiP">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" CornerRadius="18">
                                            <Path Data="M 12 12 L 24 24 M 24 12 L 12 24" Stroke="{DynamicResource OneUiTextSecondaryBrush}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-18,-18,0,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource OneUiControlBackgroundBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================== -->
    <!-- SAMSUNG STOPWATCH                              -->
    <!-- ============================================== -->
    <Style TargetType="{x:Type sui:SamsungStopwatch}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type sui:SamsungStopwatch}">
                    <Grid>
                        <StackPanel Margin="0" HorizontalAlignment="Center" MaxWidth="1200">
                            
                            <!-- Stopwatch Main Dial Card -->
                            <sui:SamsungCard x:Name="PART_MainDial" Width="360" Height="460" Margin="8" HorizontalAlignment="Center">
                                <Grid>
                                    <!-- Toggle PiP Button (Top Right corner of Card) -->
                                    <Button x:Name="PART_TogglePipButton" Width="36" Height="36" Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Cursor="Hand"
                                            ToolTip="Show Mini Stopwatch">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="18">
                                                    <!-- Icon for PiP (Picture in Picture) -->
                                                    <Path Data="M 2 2 L 14 2 L 14 10 L 2 10 Z M 8 5 L 12 5 L 12 8 L 8 8 Z" 
                                                          Stroke="{DynamicResource OneUiTextSecondaryBrush}" StrokeThickness="1.5" Fill="Transparent"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource OneUiControlBackgroundHoverBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <StackPanel HorizontalAlignment="Center">
                                        <!-- Circular Clock Face -->
                                        <Grid Width="280" Height="280" Margin="0,10,0,24">
                                            <Ellipse Fill="#121212" Stroke="#2D2D32" StrokeThickness="2"/>

                                            <!-- Digital Display centered in the clock -->
                                            <TextBlock Text="{TemplateBinding ElapsedTimeText}"
                                                       FontSize="32"
                                                       FontWeight="Bold"
                                                       Foreground="#FAFAFA"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,40,0,0"
                                                       FontFamily="Consolas, Courier New"/>

                                            <!-- Clock canvas: all elements use CenterX=140 CenterY=140 to rotate around clock center -->
                                            <Canvas Width="280" Height="280" ClipToBounds="True">
                                                <!-- === MINOR TICKS === -->
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="6"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="12"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="18"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="24"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="36"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="42"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="48"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="54"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="66"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="72"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="78"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="84"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="96"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="102"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="108"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="114"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="126"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="132"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="138"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="144"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="156"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="162"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="168"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="174"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="186"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="192"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="198"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="204"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="216"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="222"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="228"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="234"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="246"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="252"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="258"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="264"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="276"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="282"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="288"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="294"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="306"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="312"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="318"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="324"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="336"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="342"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="348"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="354"/></Line.RenderTransform>
                                                </Line>

                                                <!-- === MAJOR TICKS === -->
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#7E7E8E" StrokeThickness="2.5"/>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="30"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="60"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#7E7E8E" StrokeThickness="2.5"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="90"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="120"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="150"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#7E7E8E" StrokeThickness="2.5"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="180"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="210"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="240"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#7E7E8E" StrokeThickness="2.5"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="270"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="300"/></Line.RenderTransform></Line>
                                                <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8"><Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="330"/></Line.RenderTransform></Line>

                                                <!-- === NEEDLE === -->
                                                <Line X1="140" Y1="140" X2="140" Y2="160" Stroke="#0050AA" StrokeThickness="2.5" StrokeEndLineCap="Round">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="{Binding NeedleAngle, RelativeSource={RelativeSource TemplatedParent}}"/></Line.RenderTransform>
                                                </Line>
                                                <Line X1="140" Y1="30" X2="140" Y2="140" Stroke="#0381FE" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                    <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="{Binding NeedleAngle, RelativeSource={RelativeSource TemplatedParent}}"/></Line.RenderTransform>
                                                </Line>

                                                <!-- Center cap -->
                                                <Ellipse Width="12" Height="12" Fill="#0381FE" Canvas.Left="134" Canvas.Top="134"/>
                                                <Ellipse Width="5" Height="5" Fill="#121212" Canvas.Left="137.5" Canvas.Top="137.5"/>
                                            </Canvas>
                                        </Grid>

                                        <!-- Control Buttons -->
                                        <Grid Width="280">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button x:Name="PART_LapButton" Grid.Column="0" Width="84" Height="84" HorizontalAlignment="Left">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="42" Background="#2A2A2E" BorderThickness="1" BorderBrush="#3D3D42">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="{TemplateBinding LapButtonText}" FontSize="15" FontWeight="SemiBold" Foreground="#FAFAFA"/>
                                            </Button>

                                            <Button x:Name="PART_StartButton" Grid.Column="1" Width="84" Height="84" HorizontalAlignment="Right">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" CornerRadius="42" Background="#D1BCE3">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning, RelativeSource={RelativeSource AncestorType=sui:SamsungStopwatch}}" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="#E3A8B1"/>
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <TextBlock Text="{TemplateBinding StartButtonText}" FontSize="15" FontWeight="SemiBold" Foreground="#111111"/>
                                            </Button>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </sui:SamsungCard>

                            <!-- Live Statistics & Lap List (Hidden if no laps) -->
                            <Grid Margin="0,16,0,0">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLaps, RelativeSource={RelativeSource AncestorType=sui:SamsungStopwatch}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>

                                <WrapPanel HorizontalAlignment="Center">
                                    <!-- Lap List Card -->
                                    <sui:SamsungCard Width="350" Height="400" Margin="8" VerticalAlignment="Top">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Recorded Laps" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding Laps, RelativeSource={RelativeSource AncestorType=sui:SamsungStopwatch}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource OneUiChartLineBrush}" Padding="0,12">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding Index, StringFormat={}Lap {0}}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding LapTimeText}" FontSize="14" Foreground="{DynamicResource OneUiTextSecondaryBrush}" HorizontalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="2" Text="{Binding TotalTimeText}" FontSize="14" Foreground="{DynamicResource OneUiTextPrimaryBrush}" FontWeight="Medium"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </sui:SamsungCard>

                                    <!-- Segmented Distribution Card -->
                                    <sui:SamsungCard Width="380" Height="400" Margin="8" VerticalAlignment="Top">
                                        <Grid>
                                            <sui:SamsungSegmentedBar Segments="{Binding LapChartSegments, RelativeSource={RelativeSource AncestorType=sui:SamsungStopwatch}}"
                                                                     TitleText="Lap Breakdown" DescriptionText="Time distribution" ValueUnit="s"/>
                                        </Grid>
                                    </sui:SamsungCard>

                                    <!-- Donut Chart Card -->
                                    <sui:SamsungCard Width="360" Height="400" Margin="8" VerticalAlignment="Top">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Proportional View" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                                            <sui:SamsungDonutChart Grid.Row="1" Segments="{Binding LapChartSegments, RelativeSource={RelativeSource AncestorType=sui:SamsungStopwatch}}" 
                                                                   CenterText="Laps" CenterSubtext="Active distribution" ValueUnit="s" Height="240" VerticalAlignment="Center"/>
                                        </Grid>
                                    </sui:SamsungCard>
                                </WrapPanel>
                            </Grid>
                        </StackPanel>

                        <!-- MINI STOPWATCH PIP POPUP -->
                        <Popup x:Name="PART_MiniStopwatchPopup"
                               AllowsTransparency="True"
                               Placement="Absolute"
                               StaysOpen="True"
                               HorizontalOffset="1000"
                               VerticalOffset="100">
                            <!-- Il controllo è stato estratto in SamsungMiniStopwatch per essere un componente a sé -->
                            <sui:SamsungMiniStopwatch x:Name="PART_MiniStopwatch"
                                                      ElapsedTimeText="{Binding ElapsedTimeText, RelativeSource={RelativeSource TemplatedParent}}"
                                                      IsRunning="{Binding IsRunning, RelativeSource={RelativeSource TemplatedParent}}"
                                                      StartButtonText="{Binding StartButtonText, RelativeSource={RelativeSource TemplatedParent}}"
                                                      LapButtonText="{Binding LapButtonText, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Popup>

                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
