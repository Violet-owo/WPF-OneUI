<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:SamsungUi.Controls">

    <Style TargetType="{x:Type local:SamsungNotificationCard}">
        <!-- Fallback background if CardBackground is not set -->
        <Setter Property="CardBackground" Value="{DynamicResource OneUiControlBackgroundBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Margin" Value="16"/>
        <!-- Wide enough for details, max 400 -->
        <Setter Property="Width" Value="380"/>
        
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SamsungNotificationCard}">
                    <Border Background="{TemplateBinding CardBackground}"
                            CornerRadius="24"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            Effect="{DynamicResource OneUiPopupShadow}">
                        
                        <Grid>
                            <!-- Close button (X) top right. Negative offset to partially ignore Padding -->
                            <Button x:Name="PART_CloseButton"
                                    Content="✕"
                                    Foreground="{TemplateBinding Foreground}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    FontSize="{DynamicResource OneUiNormalFontSize}"
                                    FontWeight="Bold"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,-12,-12,0"
                                    Width="32" Height="32"
                                    Cursor="Hand"
                                    Opacity="0.6"
                                    Panel.ZIndex="10">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                                <Setter Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Grid> <!-- Notification Content -->
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,20,12">
                                <!-- Icon -->
                                <Image Source="{TemplateBinding Icon}" 
                                       Width="24" Height="24" 
                                       Margin="0,0,12,0" 
                                       VerticalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <Trigger Property="Source" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>

                                <!-- Title -->
                                <TextBlock Text="{TemplateBinding Title}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{DynamicResource OneUiSubtitleFontSize}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                                    <TextBlock Grid.Row="1"
                                               Text="{TemplateBinding Description}"
                                               Foreground="{TemplateBinding Foreground}"
                                               Opacity="0.85"
                                               FontSize="{DynamicResource OneUiNormalFontSize}"
                                               TextWrapping="Wrap"
                                               LineHeight="20"/>
                                </Grid>
                            </Grid>
                        </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
