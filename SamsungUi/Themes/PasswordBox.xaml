<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:SamsungUi.Controls">

    <!-- ============================================================ -->
    <!-- SAMSUNG PASSWORD BOX                                          -->
    <!-- Un campo password con toggle mostra/nasconde il testo.        -->
    <!-- Proprietà: Password (string), IsPasswordRevealed (bool)       -->
    <!-- ============================================================ -->
    <Style TargetType="{x:Type local:SamsungPasswordBox}">
        <Setter Property="Background" Value="{DynamicResource OneUiControlBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="MinHeight" Value="46"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SamsungPasswordBox}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Password field (masked) -->
                            <PasswordBox x:Name="PART_PasswordBox"
                                         Grid.Column="0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{TemplateBinding Foreground}"
                                         FontSize="{TemplateBinding FontSize}"
                                         VerticalAlignment="Center"
                                         CaretBrush="{DynamicResource OneUiPrimaryBrush}"
                                         Padding="0"/>

                            <!-- Plain text field (revealed) -->
                            <TextBox x:Name="PART_TextBox"
                                     Grid.Column="0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     FontSize="{TemplateBinding FontSize}"
                                     VerticalAlignment="Center"
                                     CaretBrush="{DynamicResource OneUiPrimaryBrush}"
                                     Visibility="Collapsed"
                                     Padding="0"/>

                            <!-- Reveal toggle button -->
                            <ToggleButton x:Name="PART_RevealButton"
                                          Grid.Column="1"
                                          Width="28"
                                          Height="28"
                                          Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Cursor="Hand"
                                          FocusVisualStyle="{x:Null}"
                                          IsChecked="{Binding IsPasswordRevealed, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <!-- Eye icon: visible when NOT revealed -->
                                            <TextBlock x:Name="EyeOpen"
                                                       Text="👁"
                                                       FontSize="{DynamicResource OneUiSubtitleFontSize}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.5"/>
                                            <!-- Eye-off: visible when revealed -->
                                            <TextBlock x:Name="EyeClosed"
                                                       Text="🙈"
                                                       FontSize="{DynamicResource OneUiNormalFontSize}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="Collapsed"
                                                       Opacity="0.5"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="EyeOpen" Property="Visibility" Value="Collapsed"/>
                                                <Setter TargetName="EyeClosed" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource OneUiPrimaryBrush}"/>
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource OneUiSurfaceBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
