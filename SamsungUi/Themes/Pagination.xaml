<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:SamsungUi.Controls">

    <!-- Value Converter to check if a page button is an ellipsis -->
    <local:IsEllipsisConverter x:Key="IsEllipsisConverter" />
    <local:EqualityConverter x:Key="EqualityConverter" />

    <Style TargetType="{x:Type local:SamsungPagination}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SamsungPagination}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="{TemplateBinding HorizontalAlignment}" VerticalAlignment="{TemplateBinding VerticalAlignment}">
                        
                        <!-- Previous Button -->
                        <local:SamsungButton x:Name="PART_PrevButton" 
                                             Content="&#xE76B;" 
                                             FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" 
                                             Variant="Ghost" 
                                             Width="36" Height="36" 
                                             Padding="0" 
                                             Margin="0,0,4,0" 
                                             ToolTip="Previous Page" />

                        <!-- Page Buttons -->
                        <ItemsControl ItemsSource="{TemplateBinding PageButtons}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,0">
                                        <!-- Real Button for Numbers -->
                                        <local:SamsungButton x:Name="PART_PageButton" 
                                                             Content="{Binding}" 
                                                             Width="36" Height="36" 
                                                             Padding="0" 
                                                             Variant="Ghost" 
                                                             Visibility="Visible" />
                                        
                                        <!-- Ellipsis TextBlock for "..." -->
                                        <TextBlock x:Name="PART_Ellipsis" 
                                                   Text="..." 
                                                   Width="36" Height="36" 
                                                   TextAlignment="Center" 
                                                   VerticalAlignment="Center" 
                                                   HorizontalAlignment="Center" 
                                                   Foreground="{DynamicResource OneUiTextSecondaryBrush}" 
                                                   FontWeight="Bold" 
                                                   Visibility="Collapsed" 
                                                   Margin="0,8,0,0"/>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <!-- If the item is "...", show textblock and hide button -->
                                        <DataTrigger Binding="{Binding Converter={StaticResource IsEllipsisConverter}}" Value="True">
                                            <Setter TargetName="PART_PageButton" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="PART_Ellipsis" Property="Visibility" Value="Visible" />
                                        </DataTrigger>

                                        <!-- Highlight current page -->
                                        <DataTrigger Value="True">
                                            <DataTrigger.Binding>
                                                <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                    <Binding />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=local:SamsungPagination}" Path="CurrentPage" />
                                                </MultiBinding>
                                            </DataTrigger.Binding>
                                            <Setter TargetName="PART_PageButton" Property="Variant" Value="Primary" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Next Button -->
                        <local:SamsungButton x:Name="PART_NextButton" 
                                             Content="&#xE76C;" 
                                             FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" 
                                             Variant="Ghost" 
                                             Width="36" Height="36" 
                                             Padding="0" 
                                             Margin="4,0,0,0" 
                                             ToolTip="Next Page" />
                    </StackPanel>
                    
                    <!-- Triggers to disable prev/next when at bounds -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="CurrentPage" Value="1">
                            <Setter TargetName="PART_PrevButton" Property="IsEnabled" Value="False" />
                        </Trigger>
                        <!-- To disable Next Button, we need a MultiTrigger or we handle it in code-behind. 
                             Code-behind already ignores the click, but visual disable is nice. 
                             Unfortunately we can't easily bind 'CurrentPage == TotalPages' in pure XAML Trigger without a converter. -->
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
