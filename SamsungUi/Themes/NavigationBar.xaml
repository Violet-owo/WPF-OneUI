<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:SamsungUi.Controls">

    <Style TargetType="{x:Type local:SamsungNavigationBarItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource OneUiTextSecondaryBrush}"/>
        <Setter Property="Padding" Value="24,6"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SamsungNavigationBarItem}">
                    <Border x:Name="RootBorder" 
                            Background="{TemplateBinding Background}" 
                            CornerRadius="20">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Icon}" 
                                       FontFamily="Segoe MDL2 Assets, Segoe Fluent Icons, Segoe UI Symbol" 
                                       FontSize="{DynamicResource OneUiTitleFontSize}" 
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{TemplateBinding Text}" 
                                       FontSize="{DynamicResource OneUiSmallFontSize}" 
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource OneUiTextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter TargetName="RootBorder" Property="Background" Value="Transparent"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:SamsungNavigationBar}">
        <Setter Property="Background" Value="{DynamicResource OneUiSurfaceBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:SamsungNavigationBar}">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="24"
                            Padding="{TemplateBinding Padding}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Effect="{DynamicResource OneUiModalShadow}">
                        <Grid>
                            <Canvas HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="0" ClipToBounds="True">
                                <!-- The animated pill background -->
                                <Border x:Name="PART_SelectionIndicator" 
                                        Background="{DynamicResource OneUiControlBackgroundBrush}" 
                                        CornerRadius="20"
                                        Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}"
                                        Width="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="PART_IndicatorTransform" X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Canvas>
                            <ScrollViewer Focusable="false" Background="Transparent">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
