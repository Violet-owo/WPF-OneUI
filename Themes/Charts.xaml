<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- STYLE ESTERNO PER LA BAR OPACIZZATA -->
    <Style x:Key="AnimatedBarStyle" TargetType="Border">
        <Setter Property="Opacity" Value="1"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsHighlight}" Value="False">
                <Setter Property="Opacity" Value="0.85"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- STYLE PRINCIPALE DEL BARCHART -->
    <Style x:Key="OneUiBarChartStyle" TargetType="ItemsControl">
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"
                                 Columns="{Binding Items.Count, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- SFONDO A RIGHE ALTERNATE -->
                        <Border Grid.Row="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource OneUiChartGridEvenBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ContentPresenter}, Path=(ItemsControl.AlternationIndex)}"
                                                     Value="1">
                                            <Setter Property="Background" Value="{DynamicResource OneUiChartGridOddBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- BARRA ANIMATA -->
                        <Grid Grid.Row="0" VerticalAlignment="Bottom" Height="150" Margin="4,0">
                            <Border x:Name="AnimatedBar"
                                    Style="{StaticResource AnimatedBarStyle}"
                                    Width="16"
                                    CornerRadius="8"
                                    Background="{DynamicResource OneUiChartBarBrush}"
                                    VerticalAlignment="Bottom"
                                    Height="{Binding Value}">

                                <Border.LayoutTransform>
                                    <ScaleTransform ScaleY="0"/>
                                </Border.LayoutTransform>

                                <!-- ANIMAZIONE -->
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="LayoutTransform.(ScaleTransform.ScaleY)"
                                                                 From="0"
                                                                 To="1"
                                                                 Duration="0:0:0.8"
                                                                 DecelerationRatio="0.85"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </Grid>

                        <!-- LINEA DI SEPARAZIONE -->
                        <Border Grid.Row="1" Height="1" Background="{DynamicResource OneUiChartLineBrush}"/>

                        <!-- LABEL + CERCHIO SELEZIONE -->
                        <Grid Grid.Row="2" Height="34">
                            <Border x:Name="SelectionCircle"
                                    Width="22"
                                    Height="22"
                                    CornerRadius="11"
                                    Background="{DynamicResource OneUiTextPrimaryBrush}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlight}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>

                            <TextBlock x:Name="DayLabel"
                                       Text="{Binding Label}"
                                       Foreground="{DynamicResource OneUiTextSecondaryBrush}"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlight}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource OneUiChartSelectedDayText}"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
