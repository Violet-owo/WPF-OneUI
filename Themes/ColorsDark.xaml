<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette Samsung One UI - Tema Scuro (AMOLED Friendly) -->
    <Color x:Key="OneUiBackgroundRaw">#000000</Color>
    <Color x:Key="OneUiSurfaceRaw">#121212</Color>
    <Color x:Key="OneUiPrimaryRaw">#3E99FF</Color>
    <Color x:Key="OneUiTextPrimaryRaw">#FFFFFF</Color>
    <Color x:Key="OneUiTextSecondaryRaw">#9E9E9E</Color>
    <Color x:Key="OneUiControlBackgroundRaw">#1A1A1A</Color>

    <!-- Pennelli (Brushes) pronti all'uso -->
    <SolidColorBrush x:Key="OneUiBackgroundBrush" Color="{StaticResource OneUiBackgroundRaw}"/>
    <SolidColorBrush x:Key="OneUiSurfaceBrush" Color="{StaticResource OneUiSurfaceRaw}"/>
    <SolidColorBrush x:Key="OneUiPrimaryBrush" Color="{StaticResource OneUiPrimaryRaw}"/>
    
    <SolidColorBrush x:Key="OneUiTextPrimaryBrush" Color="{StaticResource OneUiTextPrimaryRaw}"/>
    <SolidColorBrush x:Key="OneUiTextSecondaryBrush" Color="{StaticResource OneUiTextSecondaryRaw}"/>
    
    <SolidColorBrush x:Key="OneUiControlBackgroundBrush" Color="{StaticResource OneUiControlBackgroundRaw}"/>
    <SolidColorBrush x:Key="OneUiSliderActiveBrush" Color="#D1BCE3"/>
    <SolidColorBrush x:Key="OneUiSliderTrackBrush" Color="#252528"/>
    <SolidColorBrush x:Key="OneUiSliderTickBrush" Color="#5A5266"/>
    
    <SolidColorBrush x:Key="OneUiChartBarBrush" Color="#3C93FF"/>
    <SolidColorBrush x:Key="OneUiChartGridEvenBrush" Color="#18181A"/>
    <SolidColorBrush x:Key="OneUiChartGridOddBrush" Color="#1E1E22"/>
    <SolidColorBrush x:Key="OneUiChartLineBrush" Color="#2D2D32"/>
    <SolidColorBrush x:Key="OneUiChartSelectedDayText" Color="#111111"/>
    
    <SolidColorBrush x:Key="OneUiCalendarSelectedBrush" Color="#3E86F5"/>
    <SolidColorBrush x:Key="OneUiCalendarHoverBrush" Color="#2C2C2E"/>
    <SolidColorBrush x:Key="OneUiCalendarTodayTextBrush" Color="#3E86F5"/>
    <SolidColorBrush x:Key="OneUiCalendarSelectedTextBrush" Color="#FFFFFF"/>


</ResourceDictionary>