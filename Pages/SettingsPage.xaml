<sui:SamsungExpandablePage x:Class="SamsungUi.Demo.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sui="clr-namespace:SamsungUi.Controls;assembly=SamsungUi"
      Style="{DynamicResource {x:Type sui:SamsungExpandablePage}}"
      PageTitle="Settings"
      Title="Settings">

    <Grid>
        <StackPanel Margin="24,0" HorizontalAlignment="Stretch" MaxWidth="1200">
            
            <sui:SamsungTextBox x:Name="SearchBox" IsSearchBar="True" Margin="0,0,0,16" HorizontalAlignment="Stretch" TextChanged="SearchBox_TextChanged"/>
            
            <sui:SamsungTabControl x:Name="SettingsTabControl" Margin="0,0,0,16" HorizontalAlignment="Stretch">
                
                <!-- CONNECTIONS TAB -->
                <sui:SamsungTabItem Header="Connections" >
                    <StackPanel Margin="0,16,0,0" HorizontalAlignment="Stretch" Width="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=ActualWidth}" >
                        <sui:SamsungCard Margin="0,8" HorizontalAlignment="Stretch"  >
                            <StackPanel>
                                <TextBlock Text="Network settings" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                                <Grid x:Name="WiFiRow">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Wi-Fi" FontSize="16" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <sui:SamsungToggleSwitch Grid.Column="1" IsChecked="True"/>
                                </Grid>
                                <Separator x:Name="WiFiSep" Background="{DynamicResource OneUiControlBackgroundBrush}" Margin="0,16" Height="1" BorderThickness="0"/>
                                <Grid x:Name="BluetoothRow">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Bluetooth" FontSize="16" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <sui:SamsungToggleSwitch Grid.Column="1" IsChecked="False"/>
                                </Grid>
                            </StackPanel>
                        </sui:SamsungCard>
                    </StackPanel>
                </sui:SamsungTabItem>
                
                <!-- SOUNDS TAB -->
                <sui:SamsungTabItem Header="Sounds">
                    <StackPanel Margin="0,16,0,0" HorizontalAlignment="Stretch" Width="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=ActualWidth}">
                        <sui:SamsungCard Margin="0,8" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="Volume" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                                <Grid x:Name="RingtoneRow" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Ringtone" FontSize="16" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Over the Horizon" FontSize="14" Foreground="{DynamicResource OneUiPrimaryBrush}" VerticalAlignment="Center" Cursor="Hand"/>
                                </Grid>
                                <sui:SamsungSlider x:Name="RingtoneSlider" Minimum="0" Maximum="100" Value="60" />
                                
                                <Grid x:Name="MediaRow" Margin="0,16,0,8">
                                    <TextBlock Text="Media" FontSize="16" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <sui:SamsungSlider x:Name="MediaSlider" Minimum="0" Maximum="100" Value="85" />
                            </StackPanel>
                        </sui:SamsungCard>
                    </StackPanel>
                </sui:SamsungTabItem>
                
                <!-- DISPLAY TAB -->
                <sui:SamsungTabItem Header="Display">
                    <StackPanel Margin="0,16,0,0" HorizontalAlignment="Stretch">
                        <sui:SamsungCard Margin="0,8" HorizontalAlignment="Stretch" >
                            <StackPanel Width="{Binding RelativeSource={RelativeSource AncestorType=StackPanel}, Path=ActualWidth}">
                                <TextBlock Text="Display settings" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                                
                                <Grid x:Name="DarkModeRow">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Dark Mode" FontSize="16" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <sui:SamsungToggleSwitch Grid.Column="1" x:Name="ThemeModeToggle" Style="{StaticResource ThemeToggleSwitchStyle}" IsChecked="False" Checked="ThemeModeToggle_Checked" Unchecked="ThemeModeToggle_Unchecked" Margin="0,0,40,0"/>
                                </Grid>

                                <Separator Background="{DynamicResource OneUiControlBackgroundBrush}" Margin="0,16" Height="1" BorderThickness="0"/>
                                <Grid x:Name="AccentColorRow" Margin="0,0,0,12">
                                    <TextBlock Text="Accent color" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <WrapPanel x:Name="AccentColorPanel">
                                    <ItemsControl x:Name="ColorPaletteItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <RadioButton IsChecked="{Binding IsSelected, Mode=TwoWay}" Width="40" Height="40" Margin="0,0,12,12" Background="{Binding Brush}" Cursor="Hand" Checked="AccentColor_Checked" BorderThickness="0">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Grid>
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" SnapsToDevicePixels="True"/>
                                                                <Border x:Name="SelectionRing" BorderBrush="{DynamicResource OneUiSurfaceBrush}" BorderThickness="3" CornerRadius="20" Opacity="0" Margin="2">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                                                                    </Border.Effect>
                                                                </Border>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="SelectionRing" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                </RadioButton>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border x:Name="CustomColorSeparator" Width="1" Height="24" Background="{DynamicResource OneUiTextSecondaryBrush}" Opacity="0.3" Margin="4,8,16,12" Visibility="Collapsed"/>

                                    <ItemsControl x:Name="CustomColorPaletteItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <RadioButton IsChecked="{Binding IsSelected, Mode=TwoWay}" Width="40" Height="40" Margin="0,0,12,12" Background="{Binding Brush}" Cursor="Hand" Checked="AccentColor_Checked" BorderThickness="0">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Grid>
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" SnapsToDevicePixels="True"/>
                                                                <Border x:Name="SelectionRing" BorderBrush="{DynamicResource OneUiSurfaceBrush}" BorderThickness="3" CornerRadius="20" Opacity="0" Margin="2">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                                                                    </Border.Effect>
                                                                </Border>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="SelectionRing" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                </RadioButton>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <sui:SamsungButton Width="40" Height="40" Margin="0,0,0,12" Background="{DynamicResource OneUiControlBackgroundHoverBrush}" Cursor="Hand" Click="OpenColorPicker_Click" BorderThickness="0">
                                        <sui:SamsungButton.Template>
                                            <ControlTemplate TargetType="{x:Type sui:SamsungButton}">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" SnapsToDevicePixels="True">
                                                    <TextBlock Text="+" FontSize="24" FontWeight="Light" Foreground="{DynamicResource OneUiTextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-4,0,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </sui:SamsungButton.Template>
                                    </sui:SamsungButton>
                                </WrapPanel>
                            </StackPanel>
                        </sui:SamsungCard>
                    </StackPanel>
                </sui:SamsungTabItem>
            </sui:SamsungTabControl>

            <TextBlock Text="About" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="8,40,24,10" HorizontalAlignment="Left"/>
            <sui:SamsungCard Margin="8" HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Samsung UI WPF" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Version 1.0.0" FontSize="14" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="A stunning, fluent, and highly responsive WPF component library bringing the elegance of Samsung's One UI design language to desktop applications." FontSize="14" 
                               Foreground="{DynamicResource OneUiTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <sui:SamsungButton Content="Check for updates" HorizontalAlignment="Stretch" Margin="0"/>
                </StackPanel>
            </sui:SamsungCard>
            
            <!-- Bottom margin for nav bar -->
            <Grid Height="100"/>
        </StackPanel>

        <!-- Custom Color Picker Modal -->
        <sui:SamsungModal x:Name="ColorPickerModal" IsOpen="False">
            <StackPanel Width="340">
                <TextBlock Text="Custom color" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,24"/>
                
                <Border x:Name="ColorPreviewBorder" Height="80" CornerRadius="16" Background="#0381FE" Margin="0,0,0,24"/>
                
                <TextBlock Text="Red" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4"/>
                <sui:SamsungSlider x:Name="RedSlider" Minimum="0" Maximum="255" Value="3"  Margin="0,0,0,16" ValueChanged="ColorSlider_ValueChanged"/>
                
                <TextBlock Text="Green" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4"/>
                <sui:SamsungSlider x:Name="GreenSlider" Minimum="0" Maximum="255" Value="129"  Margin="0,0,0,16" ValueChanged="ColorSlider_ValueChanged"/>
                
                <TextBlock Text="Blue" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4"/>
                <sui:SamsungSlider x:Name="BlueSlider" Minimum="0" Maximum="255" Value="254"  Margin="0,0,0,32" ValueChanged="ColorSlider_ValueChanged"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <sui:SamsungButton Grid.Column="0" Content="Cancel" Click="CloseColorPicker_Click"/>
                    <sui:SamsungButton Grid.Column="2" Content="Apply" Variant="Primary" Click="ApplyCustomColor_Click"/>
                </Grid>
            </StackPanel>
        </sui:SamsungModal>

    </Grid>
</sui:SamsungExpandablePage>
