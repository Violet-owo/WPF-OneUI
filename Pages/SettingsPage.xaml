<sui:SamsungExpandablePage x:Class="SamsungUi.Demo.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sui="clr-namespace:SamsungUi.Controls;assembly=SamsungUi"
      Style="{DynamicResource {x:Type sui:SamsungExpandablePage}}"
      PageTitle="Settings"
      Title="Settings">

    <Grid>
        <StackPanel Margin="24,0" HorizontalAlignment="Stretch" MaxWidth="1200">
            
            <TextBox x:Name="SearchBox" Style="{StaticResource OneUiSearchBarStyle}" Margin="0,0,0,16" HorizontalAlignment="Stretch" TextChanged="SearchBox_TextChanged"/>
            
            <TabControl Style="{StaticResource OneUiTabControlStyle}" Margin="0,0,0,16" HorizontalAlignment="Stretch">
                
                <!-- CONNECTIONS TAB -->
                <TabItem Header="Connections" Style="{StaticResource OneUiTabItemStyle}">
                    <StackPanel Margin="0,16,0,0" HorizontalAlignment="Stretch">
                        <Border Style="{StaticResource OneUiCardStyle}" Margin="0,8" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="Network settings" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                                <Grid x:Name="WiFiRow">
                                    <TextBlock Text="Wi-Fi" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <CheckBox Style="{StaticResource OneUiToggleSwitchStyle}" HorizontalAlignment="Right" IsChecked="True"/>
                                </Grid>
                                <Separator x:Name="WiFiSep" Margin="16,16,-16,16"/>
                                <Grid x:Name="BluetoothRow">
                                    <TextBlock Text="Bluetooth" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <CheckBox Style="{StaticResource OneUiToggleSwitchStyle}" HorizontalAlignment="Right" IsChecked="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
                
                <!-- SOUNDS TAB -->
                <TabItem Header="Sounds" Style="{StaticResource OneUiTabItemStyle}">
                    <StackPanel Margin="0,16,0,0" HorizontalAlignment="Stretch">
                        <Border Style="{StaticResource OneUiCardStyle}" Margin="0,8" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="Volume" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                                <Grid x:Name="RingtoneRow" Margin="0,0,0,8">
                                    <TextBlock Text="Ringtone" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="60%" FontSize="13" Foreground="{DynamicResource OneUiSliderActiveBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="RingtoneSlider" Minimum="0" Maximum="100" Value="60" Style="{StaticResource OneUiSliderStyle}" Margin="0,0,0,16"/>
                                
                                <Grid x:Name="MediaRow" Margin="0,0,0,8">
                                    <TextBlock Text="Media" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="85%" FontSize="13" Foreground="{DynamicResource OneUiSliderActiveBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="MediaSlider" Minimum="0" Maximum="100" Value="85" Style="{StaticResource OneUiSliderStyle}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
                
                <!-- DISPLAY TAB -->
                <TabItem Header="Display" Style="{StaticResource OneUiTabItemStyle}">
                    <StackPanel Margin="0,16,0,0" HorizontalAlignment="Stretch">
                        <Border Style="{StaticResource OneUiCardStyle}" Margin="0,8" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="Display settings" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                                
                                <Grid x:Name="DarkModeRow" Margin="0,0,0,24">
                                    <TextBlock Text="Dark mode" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <CheckBox x:Name="ThemeModeToggle" Style="{StaticResource ThemeToggleSwitchStyle}" HorizontalAlignment="Right" IsChecked="False" Checked="ThemeModeToggle_Checked" Unchecked="ThemeModeToggle_Unchecked"/>
                                </Grid>

                                <Grid x:Name="AccentColorRow" Margin="0,0,0,12">
                                    <TextBlock Text="Accent color" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <WrapPanel x:Name="AccentColorPanel">
                                    <ItemsControl x:Name="ColorPaletteItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <RadioButton GroupName="Colors" IsChecked="{Binding IsSelected, Mode=TwoWay}" Width="40" Height="40" Margin="0,0,12,12" Background="{Binding Brush}" Cursor="Hand" Checked="AccentColor_Checked" BorderThickness="0">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Grid>
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" SnapsToDevicePixels="True"/>
                                                                <Border x:Name="SelectionRing" BorderBrush="{DynamicResource OneUiSurfaceBrush}" BorderThickness="3" CornerRadius="20" Opacity="0" Margin="2">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                                                                    </Border.Effect>
                                                                </Border>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="SelectionRing" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                </RadioButton>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border x:Name="CustomColorSeparator" Width="1" Height="24" Background="{DynamicResource OneUiTextSecondaryBrush}" Opacity="0.3" Margin="4,8,16,12" Visibility="Collapsed"/>

                                    <ItemsControl x:Name="CustomColorPaletteItems">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <RadioButton GroupName="Colors" IsChecked="{Binding IsSelected, Mode=TwoWay}" Width="40" Height="40" Margin="0,0,12,12" Background="{Binding Brush}" Cursor="Hand" Checked="AccentColor_Checked" BorderThickness="0">
                                                    <RadioButton.Template>
                                                        <ControlTemplate TargetType="RadioButton">
                                                            <Grid>
                                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" SnapsToDevicePixels="True"/>
                                                                <Border x:Name="SelectionRing" BorderBrush="{DynamicResource OneUiSurfaceBrush}" BorderThickness="3" CornerRadius="20" Opacity="0" Margin="2">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5"/>
                                                                    </Border.Effect>
                                                                </Border>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="SelectionRing" Property="Opacity" Value="1"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </RadioButton.Template>
                                                </RadioButton>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    
                                    <Button Width="40" Height="40" Margin="0,0,0,12" Background="{DynamicResource OneUiControlBackgroundHoverBrush}" Cursor="Hand" Click="OpenColorPicker_Click" BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="20" SnapsToDevicePixels="True">
                                                    <TextBlock Text="+" FontSize="24" FontWeight="Light" Foreground="{DynamicResource OneUiTextPrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-4,0,0"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <TextBlock Text="About" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="8,40,24,10" HorizontalAlignment="Left"/>
            <Border Style="{StaticResource OneUiCardStyle}" Margin="8" HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Samsung UI WPF" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Version 1.0.0" FontSize="14" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="A modern WPF component library inspired by Samsung One UI. Designed with fluid animations, rounded corners, and a clean minimalist aesthetic." 
                               Foreground="{DynamicResource OneUiTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <Button Content="Check for updates" Style="{StaticResource OneUiButtonStyle}" HorizontalAlignment="Stretch" Margin="0"/>
                </StackPanel>
            </Border>
            
            <!-- Bottom margin for nav bar -->
            <Grid Height="100"/>
        </StackPanel>

        <!-- Custom Color Picker Modal -->
        <sui:SamsungModal x:Name="ColorPickerModal" IsOpen="False">
            <StackPanel Width="340">
                <TextBlock Text="Custom color" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,24"/>
                
                <Border x:Name="ColorPreviewBorder" Height="80" CornerRadius="16" Background="#0381FE" Margin="0,0,0,24"/>
                
                <TextBlock Text="Red" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4"/>
                <Slider x:Name="RedSlider" Minimum="0" Maximum="255" Value="3" Style="{StaticResource OneUiSliderStyle}" Margin="0,0,0,16" ValueChanged="ColorSlider_ValueChanged"/>
                
                <TextBlock Text="Green" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4"/>
                <Slider x:Name="GreenSlider" Minimum="0" Maximum="255" Value="129" Style="{StaticResource OneUiSliderStyle}" Margin="0,0,0,16" ValueChanged="ColorSlider_ValueChanged"/>
                
                <TextBlock Text="Blue" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4"/>
                <Slider x:Name="BlueSlider" Minimum="0" Maximum="255" Value="254" Style="{StaticResource OneUiSliderStyle}" Margin="0,0,0,32" ValueChanged="ColorSlider_ValueChanged"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="Cancel" Style="{StaticResource OneUiButtonStyle}" Click="CloseColorPicker_Click"/>
                    <Button Grid.Column="2" Content="Apply" Style="{StaticResource OneUiPrimaryButtonStyle}" Click="ApplyCustomColor_Click"/>
                </Grid>
            </StackPanel>
        </sui:SamsungModal>

    </Grid>
</sui:SamsungExpandablePage>
