<sui:SamsungExpandablePage x:Class="SamsungUi.Demo.Pages.ModulesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sui="clr-namespace:SamsungUi.Controls;assembly=SamsungUi"
      Style="{DynamicResource {x:Type sui:SamsungExpandablePage}}"
      PageTitle="Modules"
      Title="ModulesPage">

    <StackPanel Margin="24,0" HorizontalAlignment="Center" MaxWidth="1200">
        <TextBlock Text="Status indicators" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="24,40,24,10" HorizontalAlignment="Left"/>

                <WrapPanel HorizontalAlignment="Left">
                    <Border Style="{StaticResource OneUiCardStyle}" Width="340" Margin="8" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Device care" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="🔋 Battery" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                    <TextBlock Text="10 h 23 m left" FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </Grid>
                                <TextBlock Text="98%" FontSize="20" FontWeight="Bold" Margin="0,4,0,8" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                <ProgressBar Value="98" Maximum="100" Style="{StaticResource OneUiProgressBarStyle}"/>
                            </StackPanel>
                            <Separator/>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="💾 Storage" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                    <TextBlock Text="225.9 GB / 256 GB" FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </Grid>
                                <TextBlock Text="88% used" FontSize="20" FontWeight="Bold" Margin="0,4,0,8" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                <ProgressBar Value="88" Maximum="100" Style="{StaticResource OneUiProgressBarStyle}"/>
                            </StackPanel>
                            <Separator/>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="⚡ Memory" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                    <TextBlock Text="8.2 GB / 12 GB" FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </Grid>
                                <TextBlock Text="67% used" FontSize="20" FontWeight="Bold" Margin="0,4,0,8" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                <ProgressBar Value="67" Maximum="100" Style="{StaticResource OneUiProgressBarStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource OneUiCardStyle}" Width="340" Margin="8" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Loading indicators" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,16">
                                <ProgressBar Style="{StaticResource OneUiProgressRingStyle}" Margin="0,0,32,0"/>
                                <ProgressBar Style="{StaticResource OneUiProgressRingStyle}" Width="24" Height="24" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource OneUiCardStyle}" Width="400" Margin="8" VerticalAlignment="Top">
                        <StackPanel>
                            <Grid Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Text="Screen time" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                    <TextBlock Text="Daily average: 2 h 41 min" FontSize="13" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Text="Details" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiSliderActiveBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                            </Grid>

                            <Grid Height="180" VerticalAlignment="Bottom" Margin="0,10,0,0">
                                <!-- ItemsSource is bound to WeeklyUsageData in code behind -->
                                <ItemsControl ItemsSource="{Binding WeeklyUsageData}" Style="{StaticResource OneUiBarChartStyle}" AlternationCount="2"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <TextBlock Text="Calendar" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="24,40,24,10" HorizontalAlignment="Left"/>

                <WrapPanel HorizontalAlignment="Left">
                    <Border Name="Calendar" Style="{StaticResource OneUiCardStyle}" Width="400" Margin="8" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="{Binding DayNumber}" 
                                       FontSize="14" 
                                       FontWeight="Medium"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource OneUiTextPrimaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                <Setter Property="Opacity" Value="0.3"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <UniformGrid Columns="7" Margin="0,0,0,4">
                                <TextBlock Text="M" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="T" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="W" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="T" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="F" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="S" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                                <TextBlock Text="S" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                            </UniformGrid>

                            <ListBox ItemsSource="{Binding CalendarDays}" 
                                     Style="{StaticResource OneUiCalendarStyle}"
                                     SelectionMode="Single"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
                
                <!-- Bottom margin for nav bar -->
                <Grid Height="100"/>
    </StackPanel>
</sui:SamsungExpandablePage>
