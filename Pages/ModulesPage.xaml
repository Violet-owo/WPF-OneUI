<sui:SamsungExpandablePage x:Class="SamsungUi.Demo.Pages.ModulesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sui="clr-namespace:SamsungUi.Controls;assembly=SamsungUi"
      Style="{DynamicResource {x:Type sui:SamsungExpandablePage}}"
      PageTitle="Modules"
      Title="ModulesPage">

    <WrapPanel Margin="24,0"  HorizontalAlignment="Stretch" MaxWidth="1200">
        <!--Status Indicator card-->
        <StackPanel>
            <TextBlock Text="Status indicators" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="24,40,24,10" HorizontalAlignment="Left"/>
            <WrapPanel HorizontalAlignment="Left">

            <!-- Device Care Card -->
            <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Device care" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>

                    <!-- Battery -->
                    <StackPanel>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔋 Battery" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="10 h 23 m left" FontSize="14" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                        </Grid>
                        <TextBlock Text="98%" FontSize="20" FontWeight="Bold" Margin="0,4,0,8" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                        <sui:SamsungProgressBar Value="98" Maximum="100"/>
                    </StackPanel>

                    <!-- Memory -->
                    <StackPanel Margin="0,16,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Memory" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="4.2 GB / 8 GB" FontSize="12" Foreground="{DynamicResource OneUiTextSecondaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <sui:SamsungProgressBar Value="88" Maximum="100"/>
                    </StackPanel>

                    <!-- Storage -->
                    <StackPanel Margin="0,16,0,0">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Storage" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="82 GB / 128 GB" FontSize="12" Foreground="{DynamicResource OneUiTextSecondaryBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <sui:SamsungProgressBar Value="67" Maximum="100"/>
                    </StackPanel>
                </StackPanel>
            </sui:SamsungCard>

            <!-- Loading Indicators Card -->
            <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Loading indicators" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,16">
                        <sui:SamsungProgressBar IsRing="True" Margin="0,0,32,0"/>
                        <sui:SamsungProgressBar IsRing="True" Width="24" Height="24" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </sui:SamsungCard>

            <!-- Screen Time Card -->
            <sui:SamsungCard Width="400" Margin="8" VerticalAlignment="Top">
                <StackPanel>
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Screen time" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                            <TextBlock Text="Daily average: 2 h 41 min" FontSize="13" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Details" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiSliderActiveBrush}" VerticalAlignment="Center" Cursor="Hand"/>
                    </Grid>

                    <Grid Height="180" VerticalAlignment="Bottom" Margin="0,10,0,0">
                        <!-- ItemsSource is bound to WeeklyUsageData in code behind -->
                        <ItemsControl ItemsSource="{Binding WeeklyUsageData}" Style="{StaticResource OneUiBarChartStyle}" AlternationCount="2"/>
                    </Grid>
                </StackPanel>
            </sui:SamsungCard>

            
        </WrapPanel>
        </StackPanel>
        <!--Calendar card-->
        <StackPanel>
            <TextBlock Text="Calendar" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="24,40,24,10" HorizontalAlignment="Left"/>
            <WrapPanel HorizontalAlignment="Left" >
            <sui:SamsungCard x:Name="Calendar" Width="400" Margin="8" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="{Binding DayNumber}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource OneUiTextPrimaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                        <Setter Property="Opacity" Value="0.3"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <UniformGrid Columns="7" Margin="0,0,0,4">
                        <TextBlock Text="M" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                        <TextBlock Text="T" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                        <TextBlock Text="W" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                        <TextBlock Text="T" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                        <TextBlock Text="F" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                        <TextBlock Text="S" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                        <TextBlock Text="S" Style="{StaticResource OneUiCalendarHeaderStyle}"/>
                    </UniformGrid>

                    <ListBox ItemsSource="{Binding CalendarDays}"
                                 Style="{StaticResource OneUiCalendarStyle}"
                                 SelectionMode="Single"/>
                </StackPanel>
            </sui:SamsungCard>
        </WrapPanel>
        </StackPanel>
        <!-- History Chart Card -->
        <StackPanel Name="ChartPanel">
            <TextBlock Text="Chart" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="24,40,24,10" HorizontalAlignment="Left"/>
            <WrapPanel HorizontalAlignment="Left" >
                <sui:SamsungCard Width="450" Margin="8" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="History data" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                <TextBlock Text="Interactive Spline Area Chart" FontSize="13" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Height="230" VerticalAlignment="Bottom">
                            <sui:SamsungLineChart Series1="{Binding HistorySeries1}"
                                       Series2="{Binding HistorySeries2}"
                                       XAxisLabels="{Binding HistoryXLabels}"
                                       SelectedIndex="9"
                                       Series1Unit="unit"
                                       Series2Unit="unit"
                                       MaxYValue="300"/>
                        </Grid>
                    </StackPanel>
                </sui:SamsungCard>
            </WrapPanel>
        </StackPanel>
 

                <!-- Bottom margin for nav bar -->
        <Grid Height="100"/>
    </WrapPanel>
</sui:SamsungExpandablePage>
