<sui:SamsungExpandablePage x:Class="SamsungUi.Demo.Pages.ControlsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sui="clr-namespace:SamsungUi.Controls;assembly=SamsungUi"
      Style="{DynamicResource {x:Type sui:SamsungExpandablePage}}"
      PageTitle="Controls"
      Title="ControlsPage">

    <Grid>
        <StackPanel Margin="24,0" HorizontalAlignment="Center" MaxWidth="1200">
            <WrapPanel HorizontalAlignment="Left">
                <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Buttons" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                        <sui:SamsungButton Content="Primary button" Variant="Primary" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                        <sui:SamsungButton Content="Secondary button" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                        <sui:SamsungButton Content="Disabled state" HorizontalAlignment="Stretch" IsEnabled="False" Margin="0"/>
                    </StackPanel>
                </sui:SamsungCard>

                <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Input fields" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Username" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4" />
                        <sui:SamsungTextBox VerticalAlignment="Top" Padding="7" Height="50" Margin="0,0,0,16" Text="JohnDoe99"/>
                        
                        <TextBlock Text="Password" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4"/>
                        <sui:SamsungPasswordBox Height="50" Password="SecretPassword"/>
                    </StackPanel>
                </sui:SamsungCard>

                <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Selection controls" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <TextBlock Text="Checkboxes" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="0,0,0,8"/>
                        <sui:SamsungCheckBox Content="Sync data" IsChecked="True" Margin="0,0,0,12"/>
                        <sui:SamsungCheckBox Content="Receive notifications" IsChecked="False" Margin="0,0,0,24"/>
                        
                        <TextBlock Text="Radio buttons" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="0,0,0,8"/>
                        <sui:SamsungRadioButton Content="Wi-Fi only" IsChecked="True" GroupName="NetworkGroup" Margin="0,0,0,12"/>
                        <sui:SamsungRadioButton Content="Over any network" IsChecked="False" GroupName="NetworkGroup" Margin="0"/>
                    </StackPanel>
                </sui:SamsungCard>

                <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Toasts &amp; feedback" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                        <sui:SamsungButton Content="Show label toast" HorizontalAlignment="Stretch" Margin="0,0,0,8" Click="ShowLabelToast_Click"/>
                        <sui:SamsungButton Content="Show action toast (auto close)" HorizontalAlignment="Stretch" Click="ShowActionToast_Click" Margin="0,0,0,8"/>
                        <sui:SamsungButton Content="Show action toast (persistent)" Variant="Primary" HorizontalAlignment="Stretch" Click="ShowPersistentActionToast_Click" Margin="0"/>
                    </StackPanel>
                </sui:SamsungCard>

                <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Quick actions" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,12"/>
                        <sui:SamsungButton Content="Wi-Fi connection" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                        <sui:SamsungButton Content="Connected devices" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                        <sui:SamsungButton Content="Sound and vibration" HorizontalAlignment="Stretch" Margin="0"/>
                    </StackPanel>
                </sui:SamsungCard>

                <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Lists" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                        <sui:SamsungListBox SelectedIndex="0" Background="{DynamicResource OneUiBackgroundBrush}" Margin="-8,0,-8,0">
                            <sui:SamsungListBoxItem>
                                <StackPanel>
                                    <TextBlock Text="Wi-Fi" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="Connected to MyNetwork" FontSize="13" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </StackPanel>
                            </sui:SamsungListBoxItem>
                            <sui:SamsungListBoxItem>
                                <StackPanel>
                                    <TextBlock Text="Bluetooth" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="On" FontSize="13" Foreground="{DynamicResource OneUiTextSecondaryBrush}"/>
                                </StackPanel>
                            </sui:SamsungListBoxItem>
                            <sui:SamsungListBoxItem>
                                <StackPanel>
                                    <TextBlock Text="NFC and payment" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </sui:SamsungListBoxItem>
                        </sui:SamsungListBox>
                    </StackPanel>
                </sui:SamsungCard>
                <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Edit variant" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                        <!-- Normal variant -->
                        <sui:SamsungEditBox Hint="Username" Text="{Binding Username}"/>
                        <!-- Password variant (automatically shows the eye icon) -->
                        <sui:SamsungEditBox Hint="Password" InputType="Password"/>
                        <!-- Numeric variant (blocks non-numeric keys) -->
                        <sui:SamsungEditBox Hint="Età" InputType="Number"/>
                    </StackPanel>
                </sui:SamsungCard>
            </WrapPanel>

            <TextBlock Text="Media &amp; volume" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="24,40,24,10" HorizontalAlignment="Left"/>

            <WrapPanel HorizontalAlignment="Left">
                <sui:SamsungCard Width="400" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Media volume" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ElementName=MediaSlider, Path=Value, StringFormat={}{0}%}" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiSliderActiveBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <sui:SamsungSlider Name="MediaSlider" Minimum="0" Maximum="100" Value="80" TickFrequency="1" IsSnapToTickEnabled="True" />
                    </StackPanel>
                </sui:SamsungCard>

                <sui:SamsungCard Width="400" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ringtone (5)" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ElementName=RingtoneSlider, Path=Value, StringFormat={}{0}%}" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiSliderActiveBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <sui:SamsungSlider Name="RingtoneSlider" Minimum="0" Maximum="100" Value="35" TickFrequency="5" IsSnapToTickEnabled="True" />
                    </StackPanel>
                </sui:SamsungCard>

                <sui:SamsungCard Width="400" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Stepped Slider (3)" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding ElementName=StepSlider, Path=Value}" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiSliderActiveBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <sui:SamsungSlider Name="StepSlider" Minimum="0" Maximum="12" Value="0" TickFrequency="3" IsSnapToTickEnabled="True" />
                    </StackPanel>
                </sui:SamsungCard>
            </WrapPanel>

            <TextBlock Text="Dialogs &amp; modals" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="24,40,24,10" HorizontalAlignment="Left"/>

            <WrapPanel HorizontalAlignment="Left">
                <sui:SamsungCard Width="340" Margin="8" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="Show modal window" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                        <sui:SamsungButton Content="Open modal" Variant="Primary" HorizontalAlignment="Stretch" Click="OpenModal_Click" Margin="0"/>
                    </StackPanel>
                </sui:SamsungCard>
            </WrapPanel>

            <Grid Height="100"/>
        </StackPanel>

        <!-- Overlay Modal -->
        <sui:SamsungModal x:Name="DemoModal" IsOpen="False">
            <StackPanel Width="300">
                <TextBlock Text="Add contact" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                
                <TextBlock Text="Full name" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4"/>
                <sui:SamsungTextBox Margin="0,0,0,16" Text="Violet Miller"/>

                <TextBlock Text="Secret password" FontSize="14" FontWeight="Medium" Foreground="{DynamicResource OneUiTextSecondaryBrush}" Margin="4,0,0,4"/>
                <sui:SamsungPasswordBox Margin="0,0,0,24" Password="SecretPassword123"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <sui:SamsungButton Grid.Column="0" Content="Cancel" Click="CloseModal_Click"/>
                    <sui:SamsungButton Grid.Column="2" Content="Save" Variant="Primary" Click="CloseModal_Click"/>
                </Grid>
            </StackPanel>
        </sui:SamsungModal>
    </Grid>
</sui:SamsungExpandablePage>
