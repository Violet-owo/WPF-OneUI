<sui:SamsungExpandablePage x:Class="SamsungUi.Demo.Pages.GalleryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sui="clr-namespace:SamsungUi.Controls;assembly=SamsungUi"
      xmlns:local="clr-namespace:SamsungUi.Demo.Pages"
      Style="{DynamicResource {x:Type sui:SamsungExpandablePage}}"
      PageTitle="Gallery"
      Title="Gallery">
      
    <Grid>
        <StackPanel Margin="0" HorizontalAlignment="Stretch">
            <sui:SamsungTabControl x:Name="GalleryTabControl" Margin="0,0,0,16" HorizontalAlignment="Stretch">
                
                <!-- BIG GRID -->
                <sui:SamsungTabItem Header="Large" >
                    <ItemsControl ItemsSource="{Binding Images}" Margin="24,16,24,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType={x:Type local:GalleryPage}}}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Border}}" />
                                    </Border.InputBindings>
                                    <sui:SamsungGridViewBig ImageSource="{Binding ImagePath}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </sui:SamsungTabItem>
                
                <!-- MEDIUM GRID -->
                <sui:SamsungTabItem Header="Medium">
                    <ItemsControl ItemsSource="{Binding Images}" Margin="20,16,20,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType={x:Type local:GalleryPage}}}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Border}}" />
                                    </Border.InputBindings>
                                    <sui:SamsungGridViewMedium ImageSource="{Binding ImagePath}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </sui:SamsungTabItem>

                <!-- SMALL GRID -->
                <sui:SamsungTabItem Header="Small">
                    <ItemsControl ItemsSource="{Binding Images}" Margin="22,16,22,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="10" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType={x:Type local:GalleryPage}}}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Border}}" />
                                    </Border.InputBindings>
                                    <sui:SamsungGridViewSmall ImageSource="{Binding ImagePath}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </sui:SamsungTabItem>
                
                <!-- LIST VIEW -->
                <sui:SamsungTabItem Header="List">
                    <ItemsControl ItemsSource="{Binding Images}" Margin="24,16,24,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Cursor="Hand">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType={x:Type local:GalleryPage}}}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Border}}" />
                                    </Border.InputBindings>
                                    <sui:SamsungListViewImageText ImageSource="{Binding ImagePath}" MainText="{Binding Title}" SubText="{Binding Date}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </sui:SamsungTabItem>
                
            </sui:SamsungTabControl>
        </StackPanel>

        <!-- FULLSCREEN PHOTO MODAL -->
        <sui:SamsungModal IsOpen="{Binding IsImageModalOpen}" OverlayStyleKey="SamsungFullscreenModalOverlayStyle">
            <Grid Background="Black">
                <!-- Image Viewer -->
                <Image Source="{Binding SelectedImage.ImagePath}" Stretch="Uniform" />

                <!-- Navigation Areas (Prev/Next) -->
                <!-- Hidden visually to behave like swipe areas for desktop clicking -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left Area -->
                    <Border Grid.Column="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding PrevImageCommand}" />
                        </Border.InputBindings>
                    </Border>

                    <!-- Right Area -->
                    <Border Grid.Column="2" Background="Transparent" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding NextImageCommand}" />
                        </Border.InputBindings>
                    </Border>
                </Grid>

                <!-- Top Bar (Back, Date, Menu) -->
                <Grid VerticalAlignment="Top" Background="#80000000" Height="72">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="72" />
                    </Grid.ColumnDefinitions>

                    <!-- Back/Close Button -->
                    <Border Grid.Column="0" Background="Transparent" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding CloseImageCommand}" />
                        </Border.InputBindings>
                        <Path Data="M20,5 L10,15 L20,25" Stroke="White" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" Stretch="Uniform" Margin="0,0,4,0"/>
                    </Border>

                    <!-- Date/Title -->
                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SelectedImage.Date}" Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedImage.Title}" Foreground="#CCCCCC" FontSize="13" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- More options (3 dots) -->
                    <Border Grid.Column="2" Background="Transparent" Cursor="Hand" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding MenuCommand}" />
                        </Border.InputBindings>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,0">
                            <Ellipse Width="4" Height="4" Fill="White" Margin="0,2.5" />
                            <Ellipse Width="4" Height="4" Fill="White" Margin="0,2.5" />
                            <Ellipse Width="4" Height="4" Fill="White" Margin="0,2.5" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Bottom Bar (Actions) -->
                <Grid VerticalAlignment="Bottom" Background="#80000000" Height="80">
                    <UniformGrid Columns="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="16,0">
                        <!-- Favorite -->
                        <Border Background="Transparent" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding FavoriteCommand}" />
                            </Border.InputBindings>
                            <Path Data="M12,21.35l-1.45-1.32C5.4,15.36,2,12.28,2,8.5C2,5.42,4.42,3,7.5,3c1.74,0,3.41,0.81,4.5,2.09C13.09,3.81,14.76,3,16.5,3C19.58,3,22,5.42,22,8.5c0,3.78-3.4,6.86-8.55,11.54L12,21.35z" 
                                  Stroke="White" StrokeThickness="1.5" Width="26" Height="26" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Fill" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedImage.IsFavorite}" Value="True">
                                                <Setter Property="Fill" Value="White" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Border>
                        <!-- Edit -->
                        <Border Background="Transparent" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding EditCommand}" />
                            </Border.InputBindings>
                            <Path Data="M3,17.25V21h3.75L17.81,9.94l-3.75-3.75L3,17.25z M20.71,7.04c0.39-0.39,0.39-1.02,0-1.41l-2.34-2.34c-0.39-0.39-1.02-0.39-1.41,0l-1.83,1.83l3.75,3.75L20.71,7.04z" 
                                  Fill="White" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Share -->
                        <Border Background="Transparent" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding ShareCommand}" />
                            </Border.InputBindings>
                            <Path Data="M18,16.08c-0.76,0-1.44,0.3-1.96,0.77L8.91,12.7c0.05-0.23,0.09-0.46,0.09-0.7s-0.04-0.47-0.09-0.7l7.05-4.11c0.54,0.5,1.25,0.81,2.04,0.81c1.66,0,3-1.34,3-3s-1.34-3-3-3s-3,1.34-3,3c0,0.24,0.04,0.47,0.09,0.7L8.04,9.81C7.5,9.31,6.79,9,6,9c-1.66,0-3,1.34-3,3s1.34,3,3,3c0.79,0,1.5-0.31,2.04-0.81l7.12,4.16c-0.05,0.21-0.08,0.43-0.08,0.65c0,1.61,1.31,2.92,2.92,2.92s2.92-1.31,2.92-2.92S19.61,16.08,18,16.08z" 
                                  Fill="White" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- Delete -->
                        <Border Background="Transparent" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding DeleteCommand}" />
                            </Border.InputBindings>
                            <Path Data="M6,19c0,1.1,0.9,2,2,2h8c1.1,0,2-0.9,2-2V7H6V19z M19,4h-3.5l-1-1h-5l-1,1H5v2h14V4z" 
                                  Fill="White" Width="24" Height="24" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Grid>
        </sui:SamsungModal>
        <!-- DIALOG MODAL -->
        <sui:SamsungModal IsOpen="{Binding IsDialogModalOpen}">
            <Border Background="{DynamicResource SamsungBackgroundSecondary}" CornerRadius="20" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.2" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{Binding DialogTitle}" FontSize="20" FontWeight="SemiBold" Margin="24,24,24,8" Foreground="{DynamicResource SamsungTextPrimary}" />
                    
                    <TextBlock Grid.Row="1" Text="{Binding DialogMessage}" FontSize="15" Margin="24,8,24,24" TextWrapping="Wrap" Foreground="{DynamicResource SamsungTextSecondary}" />
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16,8,16,16">
                        <sui:SamsungButton Content="Cancel" Command="{Binding DialogCancelCommand}" Margin="0,0,8,0" Padding="24,8">
                            <sui:SamsungButton.Style>
                                <Style TargetType="sui:SamsungButton"  BasedOn="{StaticResource {x:Type sui:SamsungButton}}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConfirmDialog}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </sui:SamsungButton.Style>
                        </sui:SamsungButton>
                        <sui:SamsungButton Content="OK" Variant="Primary" Command="{Binding DialogOkCommand}" Padding="24,8" />
                    </StackPanel>
                </Grid>
            </Border>
        </sui:SamsungModal>
    </Grid>
</sui:SamsungExpandablePage>
