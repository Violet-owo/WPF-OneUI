<sui:SamsungExpandablePage x:Class="SamsungUi.Demo.Pages.StopwatchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sui="clr-namespace:SamsungUi.Controls;assembly=SamsungUi"
      Style="{DynamicResource {x:Type sui:SamsungExpandablePage}}"
      PageTitle="Stopwatch"
      Title="StopwatchPage">

    <StackPanel Margin="24,0" HorizontalAlignment="Center" MaxWidth="1200">
        
        <!-- Stopwatch Main Dial Card -->
        <sui:SamsungCard Width="360" Height="460" Margin="8" HorizontalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                
                <!-- Circular Clock Face -->
                <Grid Width="280" Height="280" Margin="0,10,0,24">
                    <Ellipse Fill="#121212" Stroke="#2D2D32" StrokeThickness="2"/>

                    <!-- Digital Display centered in the clock -->
                    <TextBlock Text="{Binding ElapsedTimeText}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#FAFAFA"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,40,0,0"
                               FontFamily="Consolas, Courier New"/>

                    <!-- Clock canvas: all elements use CenterX=140 CenterY=140 to rotate around clock center -->
                    <Canvas Width="280" Height="280" ClipToBounds="True">

                        <!-- === MINOR TICKS (every 6°, 60 total) === -->
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="6"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="12"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="18"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="24"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="36"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="42"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="48"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="54"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="66"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="72"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="78"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="84"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="96"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="102"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="108"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="114"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="126"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="132"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="138"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="144"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="156"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="162"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="168"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="174"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="186"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="192"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="198"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="204"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="216"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="222"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="228"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="234"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="246"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="252"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="258"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="264"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="276"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="282"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="288"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="294"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="306"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="312"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="318"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="324"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="336"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="342"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="348"/></Line.RenderTransform>
                        </Line>
                        <Line X1="140" Y1="11" X2="140" Y2="18" Stroke="#333338" StrokeThickness="1">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="354"/></Line.RenderTransform>
                        </Line>

                        <!-- === MAJOR TICKS (every 30°, 12 total) - using CenterX=140 CenterY=140 === -->
                        <!-- 0° = 12 o'clock -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#7E7E8E" StrokeThickness="2.5"/>

                        <!-- 30° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="30"/></Line.RenderTransform>
                        </Line>
                        <!-- 60° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="60"/></Line.RenderTransform>
                        </Line>
                        <!-- 90° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#7E7E8E" StrokeThickness="2.5">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="90"/></Line.RenderTransform>
                        </Line>
                        <!-- 120° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="120"/></Line.RenderTransform>
                        </Line>
                        <!-- 150° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="150"/></Line.RenderTransform>
                        </Line>
                        <!-- 180° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#7E7E8E" StrokeThickness="2.5">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="180"/></Line.RenderTransform>
                        </Line>
                        <!-- 210° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="210"/></Line.RenderTransform>
                        </Line>
                        <!-- 240° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="240"/></Line.RenderTransform>
                        </Line>
                        <!-- 270° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#7E7E8E" StrokeThickness="2.5">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="270"/></Line.RenderTransform>
                        </Line>
                        <!-- 300° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="300"/></Line.RenderTransform>
                        </Line>
                        <!-- 330° -->
                        <Line X1="140" Y1="8" X2="140" Y2="22" Stroke="#4E4E5E" StrokeThickness="1.8">
                            <Line.RenderTransform><RotateTransform CenterX="140" CenterY="140" Angle="330"/></Line.RenderTransform>
                        </Line>

                        <!-- === NEEDLE: rotates correctly around center (140,140) === -->
                        <!-- Tail of needle (short, below center) -->
                        <Line X1="140" Y1="140" X2="140" Y2="160"
                              Stroke="#0050AA" StrokeThickness="2.5" StrokeEndLineCap="Round">
                            <Line.RenderTransform>
                                <RotateTransform CenterX="140" CenterY="140" Angle="{Binding NeedleAngle}"/>
                            </Line.RenderTransform>
                        </Line>
                        <!-- Main needle body (center to near top) -->
                        <Line X1="140" Y1="30" X2="140" Y2="140"
                              Stroke="#0381FE" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                            <Line.RenderTransform>
                                <RotateTransform CenterX="140" CenterY="140" Angle="{Binding NeedleAngle}"/>
                            </Line.RenderTransform>
                        </Line>

                        <!-- Center cap -->
                        <Ellipse Width="12" Height="12" Fill="#0381FE"
                                 Canvas.Left="134" Canvas.Top="134"/>
                        <Ellipse Width="5" Height="5" Fill="#121212"
                                 Canvas.Left="137.5" Canvas.Top="137.5"/>
                    </Canvas>
                </Grid>

                <!-- Control Buttons (Round in One UI style) -->
                <Grid Width="280">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lap / Reset Button -->
                    <Button Grid.Column="0" Width="84" Height="84" Click="LapReset_Click" HorizontalAlignment="Left">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="42" Background="#2A2A2E" BorderThickness="1" BorderBrush="#3D3D42">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="{Binding LapButtonText}" FontSize="15" FontWeight="SemiBold" Foreground="#FAFAFA"/>
                    </Button>

                    <!-- Start / Stop Button -->
                    <Button Grid.Column="1" Width="84" Height="84" Click="StartStop_Click" HorizontalAlignment="Right">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="42">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#D1BCE3"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Background" Value="#E3A8B1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="{Binding StartButtonText}" FontSize="15" FontWeight="SemiBold" Foreground="#111111"/>
                    </Button>
                </Grid>
            </StackPanel>
        </sui:SamsungCard>

        <!-- Live Statistics & Lap List (Hidden if no laps) -->
        <Grid Margin="0,16,0,0">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasLaps}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <WrapPanel HorizontalAlignment="Center">
                
                <!-- Lap List Card -->
                <sui:SamsungCard Width="350" Height="400" Margin="8" VerticalAlignment="Top">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Recorded Laps" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Laps}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource OneUiChartLineBrush}" Padding="0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" Text="{Binding Index, StringFormat={}Lap {0}}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding LapTimeText}" FontSize="14" Foreground="{DynamicResource OneUiTextSecondaryBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding TotalTimeText}" FontSize="14" Foreground="{DynamicResource OneUiTextPrimaryBrush}" FontWeight="Medium"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </sui:SamsungCard>

                <!-- Segmented Distribution Card -->
                <sui:SamsungCard Width="380" Height="400" Margin="8" VerticalAlignment="Top">
                    <Grid>
                        <sui:SamsungSegmentedBar Segments="{Binding LapChartSegments}"
                                                  TitleText="Lap Breakdown"
                                                  DescriptionText="Time distribution"
                                                  ValueUnit="s"
                                                 />
                    </Grid>
                </sui:SamsungCard>

                <!-- Donut Chart Card -->
                <sui:SamsungCard Width="360" Height="400" Margin="8" VerticalAlignment="Top">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Proportional View" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource OneUiTextPrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <sui:SamsungDonutChart Grid.Row="1" 
                                               Segments="{Binding LapChartSegments}" 
                                               CenterText="Laps" 
                                               CenterSubtext="Active distribution"
                                               ValueUnit="s"
                                               Height="240"
                                               VerticalAlignment="Center"/>
                    </Grid>
                </sui:SamsungCard>

            </WrapPanel>
        </Grid>

        <!-- Bottom spacer -->
        <Grid Height="100"/>
    </StackPanel>
</sui:SamsungExpandablePage>
